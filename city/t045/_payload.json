[{"data":1,"prerenderedAt":310},["Reactive",2],{"content-query-F9BG0AXvKx":3},{"_path":4,"_dir":5,"_draft":6,"_partial":6,"_locale":7,"title":8,"description":9,"image":10,"sequence":11,"category":12,"author":13,"link":14,"head":15,"publishedAt":29,"toc":30,"body":31,"_type":305,"_id":306,"_source":307,"_file":308,"_extension":309},"/city/t045","city",false,"","桃園市路邊停車 智慧停車格繳費",null,"/images/city/t045-1.jpeg",45,"交通局停車資訊網","桃園市交通局","https://epark.tycg.gov.tw/public/DeptInfo/PaymentWay",{"meta":16},[17,19,21,23,26],{"name":18,"content":7},"keywords",{"name":20,"content":7},"robots",{"name":22,"content":7},"author",{"name":24,"content":25},"copyright","© 2024 A7新林口-社區網站",{"name":27,"content":28},"og:title","地方行政","2026-01-03T00:00:00.000Z",true,{"type":32,"children":33,"toc":298},"root",[34,42,48,58,63,114,122,127,157,165,170,225,253,285],{"type":35,"tag":36,"props":37,"children":39},"element","h2",{"id":38},"桃園市路邊停車-智慧停車格繳費",[40],{"type":41,"value":8},"text",{"type":35,"tag":43,"props":44,"children":46},"h3",{"id":45},"智慧停車格繳費方式",[47],{"type":41,"value":45},{"type":35,"tag":49,"props":50,"children":51},"p",{},[52],{"type":35,"tag":53,"props":54,"children":55},"strong",{},[56],{"type":41,"value":57},"1. 🏪 超商補單繳費",{"type":35,"tag":49,"props":59,"children":60},{},[61],{"type":41,"value":62},"適合習慣去便利商店繳費，但車上沒有停車單的居民。",{"type":35,"tag":64,"props":65,"children":66},"ul",{},[67,80,92,97],{"type":35,"tag":68,"props":69,"children":70},"li",{},[71,73,78],{"type":41,"value":72},"步驟一：於",{"type":35,"tag":53,"props":74,"children":75},{},[76],{"type":41,"value":77},"停車完成三小時後",{"type":41,"value":79},"，前往全國 7-11、全家、萊爾富或 OK 超商。",{"type":35,"tag":68,"props":81,"children":82},{},[83,85,90],{"type":41,"value":84},"步驟二：操作多媒體機台（如 ibon、FamiPort 等），輸入",{"type":35,"tag":53,"props":86,"children":87},{},[88],{"type":41,"value":89},"車號",{"type":41,"value":91},"查詢停車資訊。",{"type":35,"tag":68,"props":93,"children":94},{},[95],{"type":41,"value":96},"步驟三：列印**補單（小白單）**後，交給櫃檯人員完成繳費。",{"type":35,"tag":68,"props":98,"children":99},{},[100,105,107,112],{"type":35,"tag":53,"props":101,"children":102},{},[103],{"type":41,"value":104},"注意",{"type":41,"value":106},"：繳費後請務必索取並",{"type":35,"tag":53,"props":108,"children":109},{},[110],{"type":41,"value":111},"保存收據至少 6 個月",{"type":41,"value":113},"，以利日後查證。",{"type":35,"tag":49,"props":115,"children":116},{},[117],{"type":35,"tag":53,"props":118,"children":119},{},[120],{"type":41,"value":121},"2. 📱 行動支付 (APP 繳費)",{"type":35,"tag":49,"props":123,"children":124},{},[125],{"type":41,"value":126},"透過手機 APP 隨時查詢、隨時付費，不需紙本單據。",{"type":35,"tag":64,"props":128,"children":129},{},[130,140,152],{"type":35,"tag":68,"props":131,"children":132},{},[133,134,138],{"type":41,"value":72},{"type":35,"tag":53,"props":135,"children":136},{},[137],{"type":41,"value":77},{"type":41,"value":139},"，打開合作之行動支付 APP（如：全支付, 悠遊付, 街口支付、Pi 拍錢包、車麻吉等）。",{"type":35,"tag":68,"props":141,"children":142},{},[143,145,150],{"type":41,"value":144},"步驟二：選擇「路邊停車費」功能，透過",{"type":35,"tag":53,"props":146,"children":147},{},[148],{"type":41,"value":149},"車號查詢",{"type":41,"value":151},"找出未繳帳單。",{"type":35,"tag":68,"props":153,"children":154},{},[155],{"type":41,"value":156},"步驟三：確認金額後，直接使用信用卡或儲值帳戶進行支付。",{"type":35,"tag":49,"props":158,"children":159},{},[160],{"type":35,"tag":53,"props":161,"children":162},{},[163],{"type":41,"value":164},"3. 🏦 金融、電信業者代扣繳",{"type":35,"tag":49,"props":166,"children":167},{},[168],{"type":41,"value":169},"最推薦的自動化方式，可徹底避免因忙碌遺忘繳費而受罰。",{"type":35,"tag":64,"props":171,"children":172},{},[173,192,204,216],{"type":35,"tag":68,"props":174,"children":175},{},[176,178,183,185,190],{"type":41,"value":177},"步驟一：向桃園市合作之",{"type":35,"tag":53,"props":179,"children":180},{},[181],{"type":41,"value":182},"金融機構",{"type":41,"value":184},"（如中國信託、玉山銀行）或",{"type":35,"tag":53,"props":186,"children":187},{},[188],{"type":41,"value":189},"電信業者",{"type":41,"value":191},"（如中華電信、遠傳、台灣大哥大、遠通電收）申請代扣繳服務。",{"type":35,"tag":68,"props":193,"children":194},{},[195,197,202],{"type":41,"value":196},"步驟二：將車號與信用卡、銀行帳戶或電話帳單完成",{"type":35,"tag":53,"props":198,"children":199},{},[200],{"type":41,"value":201},"授權綁定",{"type":41,"value":203},"。",{"type":35,"tag":68,"props":205,"children":206},{},[207,209,214],{"type":41,"value":208},"步驟三：未來產生停車費時，系統將在",{"type":35,"tag":53,"props":210,"children":211},{},[212],{"type":41,"value":213},"繳費期限截止前自動扣帳",{"type":41,"value":215},"，無需任何手動操作。",{"type":35,"tag":68,"props":217,"children":218},{},[219,223],{"type":35,"tag":53,"props":220,"children":221},{},[222],{"type":41,"value":104},{"type":41,"value":224},"：每部車輛僅能由一家業者綁定，若車輛異動（如轉售）需主動向業者申請終止。",{"type":35,"tag":49,"props":226,"children":227},{},[228,233,235,240,242,246,251],{"type":35,"tag":53,"props":229,"children":230},{},[231],{"type":41,"value":232},"💡 重要提醒：",{"type":41,"value":234}," 依據來源，路邊停車應於 ",{"type":35,"tag":53,"props":236,"children":237},{},[238],{"type":41,"value":239},"14 日內",{"type":41,"value":241},"繳納，逾期將會收到催繳通知並產生工本費。",{"type":35,"tag":243,"props":244,"children":245},"br",{},[],{"type":35,"tag":53,"props":247,"children":248},{},[249],{"type":41,"value":250},"💡 參考資料:",{"type":41,"value":252}," 桃園市政府交通局停車資訊網：",{"type":35,"tag":64,"props":254,"children":255},{},[256,270],{"type":35,"tag":68,"props":257,"children":258},{},[259],{"type":35,"tag":260,"props":261,"children":264},"a",{"href":14,"rel":262},[263],"nofollow",[265],{"type":35,"tag":53,"props":266,"children":267},{},[268],{"type":41,"value":269},"繳付管道說明",{"type":35,"tag":68,"props":271,"children":272},{},[273,283],{"type":35,"tag":260,"props":274,"children":277},{"href":275,"rel":276},"https://epark.tycg.gov.tw/public/Ticket/PrintApp",[263],[278],{"type":35,"tag":53,"props":279,"children":280},{},[281],{"type":41,"value":282},"行動支付入口",{"type":41,"value":284},"網頁",{"type":35,"tag":49,"props":286,"children":287},{},[288,294],{"type":35,"tag":289,"props":290,"children":293},"img",{"alt":291,"src":292},"t045-2.jpeg","/images/city/t045-2.jpeg",[],{"type":35,"tag":289,"props":295,"children"