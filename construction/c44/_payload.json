[{"data":1,"prerenderedAt":587},["Reactive",2],{"content-query-JeukD2SScQ":3},{"_path":4,"_dir":5,"_draft":6,"_partial":6,"_locale":7,"title":8,"description":9,"image":10,"sequence":11,"category":12,"status":13,"type":14,"budget":9,"link":9,"head":15,"publishedAt":29,"toc":30,"body":31,"_type":582,"_id":583,"_source":584,"_file":585,"_extension":586},"/construction/c44","construction",false,"","變四 樂善一路打通工程",null,"/images/construction/c44-1.jpeg",44,"交通發展","3.規劃","red",{"meta":16},[17,19,21,23,26],{"name":18,"content":7},"keywords",{"name":20,"content":7},"robots",{"name":22,"content":7},"author",{"name":24,"content":25},"copyright","© 2024 A7新林口-社區網站",{"name":27,"content":28},"og:title","地方行政","2029-12-31T00:00:00.000Z",true,{"type":32,"children":33,"toc":573},"root",[34,43,49,79,84,97,106,111,152,160,239,247,252,298,306,361,369,445,453,458,502,515,520,546,551,556,561,566],{"type":35,"tag":36,"props":37,"children":39},"element","h2",{"id":38},"變四-樂善一路開通",[40],{"type":41,"value":42},"text","變四 樂善一路開通",{"type":35,"tag":44,"props":45,"children":47},"h3",{"id":46},"計畫概要",[48],{"type":41,"value":46},{"type":35,"tag":50,"props":51,"children":52},"ul",{},[53,59,64,69,74],{"type":35,"tag":54,"props":55,"children":56},"li",{},[57],{"type":41,"value":58},"項目 變四 樂善一路打通工程",{"type":35,"tag":54,"props":60,"children":61},{},[62],{"type":41,"value":63},"類別 交通建設 - CON-44",{"type":35,"tag":54,"props":65,"children":66},{},[67],{"type":41,"value":68},"日期 2029/12/31 (都市計畫發布實施後 3 年內完成)",{"type":35,"tag":54,"props":70,"children":71},{},[72],{"type":41,"value":73},"經費 1.82億元",{"type":35,"tag":54,"props":75,"children":76},{},[77],{"type":41,"value":78},"狀態 規劃 - 都是計劃變更中",{"type":35,"tag":44,"props":80,"children":82},{"id":81},"計劃詳情",[83],{"type":41,"value":81},{"type":35,"tag":85,"props":86,"children":87},"p",{},[88,95],{"type":35,"tag":89,"props":90,"children":92},"a",{"href":91},"https://www.facebook.com/share/p/18G8HjNwey/",[93],{"type":41,"value":94},"樂善一路打通工程 都計變更案 說明會 2026/03/16",{"type":41,"value":96},":",{"type":35,"tag":85,"props":98,"children":99},{},[100],{"type":35,"tag":101,"props":102,"children":103},"strong",{},[104],{"type":41,"value":105},"一、 計畫緣起與目的",{"type":35,"tag":85,"props":107,"children":108},{},[109],{"type":41,"value":110},"本計畫旨在配合「樂善一路打通工程」，解決林口特定區（特別是 A7 重劃區）目前的交通瓶頸。",{"type":35,"tag":50,"props":112,"children":113},{},[114,124],{"type":35,"tag":54,"props":115,"children":116},{},[117,122],{"type":35,"tag":101,"props":118,"children":119},{},[120],{"type":41,"value":121},"現況問題",{"type":41,"value":123},"：A7 重劃區主要依賴文化一路及文學路，周邊道路系統尚未完全開闢，導致車流過度集中於文化一路，造成尖峰時段交通嚴重壅塞，且外部交通需繞行，缺乏南北向替代道路。",{"type":35,"tag":54,"props":125,"children":126},{},[127,132,134],{"type":35,"tag":101,"props":128,"children":129},{},[130],{"type":41,"value":131},"計畫目標",{"type":41,"value":133},"：\n",{"type":35,"tag":50,"props":135,"children":136},{},[137,142,147],{"type":35,"tag":54,"props":138,"children":139},{},[140],{"type":41,"value":141},"串聯周邊道路，加強地區道路系統。",{"type":35,"tag":54,"props":143,"children":144},{},[145],{"type":41,"value":146},"建置替代道路，紓解交通負擔。",{"type":35,"tag":54,"props":148,"children":149},{},[150],{"type":41,"value":151},"改善居住環境，並提升急難救災的便捷性。",{"type":35,"tag":85,"props":153,"children":154},{},[155],{"type":35,"tag":101,"props":156,"children":157},{},[158],{"type":41,"value":159},"二、 計畫位置與變更範圍",{"type":35,"tag":50,"props":161,"children":162},{},[163,173,183,200],{"type":35,"tag":54,"props":164,"children":165},{},[166,171],{"type":35,"tag":101,"props":167,"children":168},{},[169],{"type":41,"value":170},"計畫位置",{"type":41,"value":172},"：位於林口特定區計畫之東南側（桃園市龜山區）。",{"type":35,"tag":54,"props":174,"children":175},{},[176,181],{"type":35,"tag":101,"props":177,"children":178},{},[179],{"type":41,"value":180},"現狀地景",{"type":41,"value":182},"：基地目前多為闊葉林、未使用土地及河川使用（水溝用地）。",{"type":35,"tag":54,"props":184,"children":185},{},[186,191,193,198],{"type":35,"tag":101,"props":187,"children":188},{},[189],{"type":41,"value":190},"變更面積",{"type":41,"value":192},"：總計約 ",{"type":35,"tag":101,"props":194,"children":195},{},[196],{"type":41,"value":197},"0.64 公頃",{"type":41,"value":199},"（約 6,434 平方公尺）。",{"type":35,"tag":54,"props":201,"children":202},{},[203,208,209],{"type":35,"tag":101,"props":204,"children":205},{},[206],{"type":41,"value":207},"土地權屬",{"type":41,"value":133},{"type":35,"tag":50,"props":210,"children":211},{},[212,217,227],{"type":35,"tag":54,"props":213,"children":214},{},[215],{"type":41,"value":216},"主要為桃園市龜山區樂善捷段等 31 筆土地。",{"type":35,"tag":54,"props":218,"children":219},{},[220,225],{"type":35,"tag":101,"props":221,"children":222},{},[223],{"type":41,"value":224},"私有土地約佔 72%",{"type":41,"value":226},"，公有土地約佔 28%。",{"type":35,"tag":54,"props":228,"children":229},{},[230,232,237],{"type":41,"value":231},"範圍內目前",{"type":35,"tag":101,"props":233,"children":234},{},[235],{"type":41,"value":236},"無既有建物",{"type":41,"value":238},"需拆遷。",{"type":35,"tag":85,"props":240,"children":241},{},[242],{"type":35,"tag":101,"props":243,"children":244},{},[245],{"type":41,"value":246},"三、 變更內容摘要",{"type":35,"tag":85,"props":248,"children":249},{},[250],{"type":41,"value":251},"本案將現行的農業區、保護區、水溝用地及道路用地進行調整，具體變更如下：",{"type":35,"tag":50,"props":253,"children":254},{},[255,272,288],{"type":35,"tag":54,"props":256,"children":257},{},[258,263,265,270],{"type":35,"tag":101,"props":259,"children":260},{},[261],{"type":41,"value":262},"道路用地",{"type":41,"value":264},"：由原計畫的農業區 (0.19 ha)、保護區 (0.32 ha) 及水溝用地 (0.04 ha) 變更而來，總計新設 ",{"type":35,"tag":101,"props":266,"children":267},{},[268],{"type":41,"value":269},"0.55 公頃",{"type":41,"value":271},"。",{"type":35,"tag":54,"props":273,"children":274},{},[275,280,282,287],{"type":35,"tag":101,"props":276,"children":277},{},[278],{"type":41,"value":279},"綠地用地",{"type":41,"value":281},"：由原道路用地變更為綠地，面積為 ",{"type":35,"tag":101,"props":283,"children":284},{},[285],{"type":41,"value":286},"0.09 公頃",{"type":41,"value":271},{"type":35,"tag":54,"props":289,"children":290},{},[291,296],{"type":35,"tag":101,"props":292,"children":293},{},[294],{"type":41,"value":295},"保護區",{"type":41,"value":297},"：部分水溝用地調整為保護區。",{"type":35,"tag":85,"props":299,"children":300},{},[301],{"type":35,"tag":101,"props":302,"children":303},{},[304],{"type":41,"value":305},"四、 交通系統規劃細節",{"type":35,"tag":50,"props":307,"children":308},{},[309,351],{"type":35,"tag":54,"props":310,"children":311},{},[312,317,318],{"type":35,"tag":101,"props":313,"children":314},{},[315],{"type":41,"value":316},"道路設置原則",{"type":41,"value":133},{"type":35,"tag":50,"props":319,"children":320},{},[321,331,341],{"type":35,"tag":54,"props":322,"children":323},{},[324,329],{"type":35,"tag":101,"props":325,"children":326},{},[327],{"type":41,"value":328},"主幹道（樂善一路）",{"type":41,"value":330},"：計畫路權寬度 20 公尺，實際路寬 15 公尺。配置雙向各二車道（含二混和車道及路肩）。",{"type":35,"tag":54,"props":332,"children":333},{},[334,339],{"type":35,"tag":101,"props":335,"children":336},{},[337],{"type":41,"value":338},"支道",{"type":41,"value":340},"：計畫路權寬度 8 公尺，實際路寬 5 公尺。規劃為單向單車道，用以銜接文學路。",{"type":35,"tag":54,"props":342,"children":343},{},[344,349],{"type":35,"tag":101,"props":345,"children":346},{},[347],{"type":41,"value":348},"設計調整",{"type":41,"value":350},"：為避免影響響應式歷史建物，部分路段向東偏移。",{"type":35,"tag":54,"props":352,"children":353},{},[354,359],{"type":35,"tag":101,"props":355,"children":356},{},[357],{"type":41,"value":358},"拓寬路段",{"type":41,"value":360},"：預計長度約 330 公尺，寬度約 20 公尺。",{"type":35,"tag":85,"props":362,"children":363},{},[364],{"type":35,"tag":101,"props":365,"children":366},{},[367],{"type":41,"value":368},"五、 實施進度與預估經費",{"type":35,"tag":50,"props":370,"children":371},{},[372,388,410],{"type":35,"tag":54,"props":373,"children":374},{},[375,380,382,387],{"type":35,"tag":101,"props":376,"children":377},{},[378],{"type":41,"value":379},"預計進度",{"type":41,"value":381},"：計畫預計於都市計畫發布實施後 ",{"type":35,"tag":101,"props":383,"children":384},{},[385],{"type":41,"value":386},"3 年內完成",{"type":41,"value":271},{"type":35,"tag":54,"props":389,"children":390},{},[391,396,397],{"type":35,"tag":101,"props":392,"children":393},{},[394],{"type":41,"value":395},"土地取得方式",{"type":41,"value":133},{"type":35,"tag":50,"props":398,"children":399},{},[400,405],{"type":35,"tag":54,"props":401,"children":402},{},[403],{"type":41,"value":404},"公有土地：無償撥用或管理機關變更。",{"type":35,"tag":54,"props":406,"children":407},{},[408],{"type":41,"value":409},"私有土地：優先採取協議價購，若協議不成則採一般徵收。",{"type":35,"tag":54,"props":411,"children":412},{},[413,418,420,425,427],{"type":35,"tag":101,"props":414,"children":415},{},[416],{"type":41,"value":417},"預估開發經費",{"type":41,"value":419},"：約 ",{"type":35,"tag":101,"props":421,"children":422},{},[423],{"type":41,"value":424},"1.82 億元",{"type":41,"value":426},"。\n",{"type":35,"tag":50,"props":428,"children":429},{},[430,435,440],{"type":35,"tag":54,"props":431,"children":432},{},[433],{"type":41,"value":434},"私有土地補償費：約 7,867 萬元。",{"type":35,"tag":54,"props":436,"children":437},{},[438],{"type":41,"value":439},"工程費：約 1.03 億元。",{"type":35,"tag":54,"props":441,"children":442},{},[443],{"type":41,"value":444},"主辦單位：桃園市政府。",{"type":35,"tag":85,"props":446,"children":447},{},[448],{"type":35,"tag":101,"props":449,"children":450},{},[451],{"type":41,"value":452},"六、 預期效益",{"type":35,"tag":85,"props":454,"children":455},{},[456],{"type":41,"value":457},"本計畫完成後，將能有效分散文化一路的交通流量，改善龜山地區通往林口的通勤壅塞問題。若不執行此改善工程，預期未來該地區的交通服務水準將惡化至 E 級（嚴重壅塞）。",{"type":35,"tag":85,"props":459,"children":460},{},[461,467,472,477,482,487,492,497],{"type":35,"tag":462,"props":463,"children":466},"img",{"alt":464,"src":465},"c44-2.jpg","/images/construction/c44-2.jpg",[],{"type":35,"tag":462,"props":468,"children":471},{"alt":469,"src":470},"c44-3.jpg","/images/construction/c44-3.jpg",[],{"type":35,"tag":462,"props":473,"children":476},{"alt":474,"src":475},"c44-4.jpg","/images/construction/c44-4.jpg",[],{"type":35,"tag":462,"props":478,"children":481},{"alt":479,"src":480},"c44-5.jpg","/images/construction/c44-5.jpg",[],{"type":35,"tag":462,"props":483,"children":486},{"alt":484,"src":485},"c44-6.jpg","/images/construction/c44-6.jpg",[],{"type":35,"tag":462,"props":488,"children":491},{"alt":489,"src":490},"c44-7.jpg","/images/construction/c44-7.jpg",[],{"type":35,"tag":462,"props":493,"children":496},{"alt":494,"src":495},"c44-8.jpg","/images/construction/c44-8.jpg",[],{"type":35,"tag":462,"props":498,"children":501},{"alt":499,"src":500},"c44-9.jpg","/images/construction/c44-9.jpg",[],{"type":35,"tag":85,"props":503,"children":504},{},[505,507,513],{"type":41,"value":506},"依據 ",{"type":35,"tag":89,"props":508,"children":510},{"href":509},"https://www.facebook.com/share/p/14UyYtrmpS/",[511],{"type":41,"value":512},"李宗豪議員",{"type":41,"value":514}," 2024/12/11 FB:",{"type":35,"tag":85,"props":516,"children":517},{},[518],{"type":41,"value":519},"於 2024/12/10 日質詢都發局：",{"type":35,"tag":85,"props":521,"children":522},{},[523,528,532,537,539,544],{"type":35,"tag":101,"props":524,"children":525},{},[526],{"type":41,"value":527},"樂善一路打通",{"type":35,"tag":529,"props":530,"children":531},"br",{},[],{"type":35,"tag":101,"props":533,"children":534},{},[535],{"type":41,"value":536},"工務局道路規劃草案已經完成",{"type":41,"value":538},"，於 11 月舉辦公展前說明會，",{"type":35,"tag":101,"props":540,"children":541},{},[542],{"type":41,"value":543},"目前正在準備變更都市計畫",{"type":41,"value":545},"，我要求都發局變更進度要加快，未來樂善一路打通後，變一銜接變二，才能完善聯外路網，讓居民更加便利。",{"type":35,"tag":44,"props":547,"children":549},{"id":548},"備註",[550],{"type":41,"value":548},{"type":35,"tag":85,"props":552,"children":553},{},[554],{"type":41,"value":555},"樂善一路在原有的 A7 重劃區是由牛角坡段的樂善一路銜接合宜社宅的樂善一路。這項工程後來似乎被刪除了？",{"type":35,"tag":85,"props":557,"children":558},{},[559],{"type":41,"value":560},"感謝宗豪議員能再次提出！希望能看到此項工程的再次被喚醒。 將對目前合宜住宅區的學童前往文青國中小的一大交通利多。希望有更多的議員加入催生此一工程案的實現。",{"type":35,"tag":85,"props":562,"children":563},{},[564],{"type":41,"value":565},"當變一:文學路延伸案及變二: 牛角坡路延伸 兩案 加上 樂善一路開通 將給 A7 重劃區一個綠色區塊。如果能於其中建立樹梢步道 就能形成一個樹梢步道公園。 可以給 A7 重劃區一個美好未來的想像空間。",{"type":35,"tag":85,"props":567,"children":568},{},[569],{"type":35,"tag":462,"props":570,"children":572},{"alt":571,"src":10},"c44-1.jpeg",[],{"title":7,"searchDepth":574,"depth":574,"links":575},2,[576],{"id":38,"depth":574,"text":42,"children":577},[578,580,581],{"id":46,"depth":579,"text":46},3,{"id":81,"depth":579,"text":81},{"id":548,"depth":579,"text":548},"markdown","content:construction:c44.md","content","construction/c44.md","md",1775809022486]