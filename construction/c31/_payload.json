[{"data":1,"prerenderedAt":445},["Reactive",2],{"content-query-dxNFHZXnQS":3},{"_path":4,"_dir":5,"_draft":6,"_partial":6,"_locale":7,"title":8,"description":9,"image":9,"sequence":10,"category":11,"status":12,"type":13,"budget":9,"link":9,"head":14,"publishedAt":28,"toc":29,"body":30,"_type":440,"_id":441,"_source":442,"_file":443,"_extension":444},"/construction/c31","construction",false,"","文資園區 協和磚窯場的修復再利用計畫",null,31,"工商發展","2.施工","yellow",{"meta":15},[16,18,20,22,25],{"name":17,"content":7},"keywords",{"name":19,"content":7},"robots",{"name":21,"content":7},"author",{"name":23,"content":24},"copyright","© 2024 A7新林口-社區網站",{"name":26,"content":27},"og:title","地方行政","2028-12-31T00:00:00.000Z",true,{"type":31,"children":32,"toc":430},"root",[33,41,47,72,85,90,99,110,115,120,125,130,135,140,145,153,158,186,193,198,211,217,243,248,254,259,264,269,280,290,302,308,328,334,336],{"type":34,"tag":35,"props":36,"children":38},"element","h2",{"id":37},"文資園區-協和磚窯場的修復再利用計畫",[39],{"type":40,"value":8},"text",{"type":34,"tag":42,"props":43,"children":45},"h3",{"id":44},"計畫概要",[46],{"type":40,"value":44},{"type":34,"tag":48,"props":49,"children":50},"ul",{},[51,57,62,67],{"type":34,"tag":52,"props":53,"children":54},"li",{},[55],{"type":40,"value":56},"項目 協和磚窯場的修復再利用計畫",{"type":34,"tag":52,"props":58,"children":59},{},[60],{"type":40,"value":61},"類別 居住環境 - CON-31",{"type":34,"tag":52,"props":63,"children":64},{},[65],{"type":40,"value":66},"經費",{"type":34,"tag":52,"props":68,"children":69},{},[70],{"type":40,"value":71},"狀態 施工",{"type":34,"tag":73,"props":74,"children":75},"p",{},[76,83],{"type":34,"tag":77,"props":78,"children":80},"a",{"href":79},"https://www.facebook.com/share/p/1EyyzeRTFj/",[81],{"type":40,"value":82},"臉書 2026/01/26",{"type":40,"value":84},"A7磚窯文化園區:",{"type":34,"tag":73,"props":86,"children":87},{},[88],{"type":40,"value":89},"當初有2個窯，一個永基窯、另一個協合窯。近日機捷站旁的一個煙𠧧被拆除是因為它是私人所有，此煙𠧧隸屬「永基窯」，而「永基窯」就在畫紅色箭頭那兒，但早就被拆除。\n政府保留「協合窯」和旁邊的煙𠧧是因已被政府徵收。所以磚窯文化園區仍照計劃進行",{"type":34,"tag":73,"props":91,"children":92},{},[93],{"type":34,"tag":94,"props":95,"children":98},"img",{"alt":96,"src":97},"c31-2.jpeg","/images/construction/c31-2.jpeg",[],{"type":34,"tag":73,"props":100,"children":101},{},[102,108],{"type":34,"tag":77,"props":103,"children":105},{"href":104},"https://www.facebook.com/100070641173347/videos/1967731320466507/",[106],{"type":40,"value":107},"樂善新鮮事",{"type":40,"value":109}," 2025/10/01:",{"type":34,"tag":73,"props":111,"children":112},{},[113],{"type":40,"value":114},"A7 煙囪磚窯廠即將變身~~ #從教室到社區 #孩子提案納入地方規劃",{"type":34,"tag":73,"props":116,"children":117},{},[118],{"type":40,"value":119},"「哇!我們家旁邊的煙囪磚窯廠，變成上課中跟同學一起規劃的文創園區，而且要成真了耶」",{"type":34,"tag":73,"props":121,"children":122},{},[123],{"type":40,"value":124},"114 年 9 月桃園市文化局帶來好消息說，位於學校旁邊的機場捷運 A7 站區的「變 1」道路工程，因需同步保留重要「文資磚窯廠遺跡」需求將原高架改為地下化，確認已於 2025 年 8 月底決標，並將於 2028 年完工，未來將打通文學路，以紓解當地交通壅塞問題。\n因此，文化局需同步啟動「磚窯廠古蹟保留」後之規劃設計，也因此找上了樂善國小…",{"type":34,"tag":73,"props":126,"children":127},{},[128],{"type":40,"value":129},"FB 2023/11/08 龜山樟腦寮協和磚廠」變更修復再利用計畫暨結構安全檢測評估，2023/11/08 日公告決標。\n桃園市歷史建築龜山樟腦寮協和磚廠調查研究暨修復再利用計畫 2022/08/10 說明會",{"type":34,"tag":73,"props":131,"children":132},{},[133],{"type":40,"value":134},"2022 取得道路用地, 道路工程 2022 年底發包 2025 年完工; 歷史建築修復將於道路工程完工後啟動, 預計 2026 年開放",{"type":34,"tag":42,"props":136,"children":138},{"id":137},"建設詳情",[139],{"type":40,"value":137},{"type":34,"tag":73,"props":141,"children":142},{},[143],{"type":40,"value":144},"龜山區為桃園市首要排名的磚窯區域，主要是因為二戰後所興起的八卦窯，其中，龜山區協和磚廠作為代表性的八卦窯建築，見證桃園地區經濟起飛及城鄉發展的共同記憶，其以林口台地之紅土製磚，可以呈現磚窯產業脈絡，以及代表地方文化的地區性建造物類型。",{"type":34,"tag":73,"props":146,"children":147},{},[148],{"type":34,"tag":94,"props":149,"children":152},{"alt":150,"src":151},"c31-1.jpeg","/images/construction/c31-1.jpeg",[],{"type":34,"tag":42,"props":154,"children":156},{"id":155},"歷史沿革",[157],{"type":40,"value":155},{"type":34,"tag":73,"props":159,"children":160},{},[161,163,169,171,177,179,184],{"type":40,"value":162},"依據 ",{"type":34,"tag":77,"props":164,"children":166},{"href":165},"https://sites.google.com/gapps.uch.edu.tw/history/%E7%94%A2%E6%A5%AD%E6%96%87%E5%8C%96/%E7%A3%9A%E7%AA%AF%E7%94%A2%E6%A5%AD",[167],{"type":40,"value":168},"龜山數位典藏",{"type":40,"value":170},":\n「龜山樟腦寮磚窯廠」是桃園市僅存的一座八卦窯廠，位於桃園機場捷運 A7 站正後方，地方社群一直有保留再生的呼聲，但在 2020/8/27 地主整地時不慎位於桃園機場捷運 A7 站正後方破壞了樟腦寮磚窯廠的部分結構，桃園市政府文化局已於 8 月 27 日公告該地為「",{"type":34,"tag":172,"props":173,"children":174},"strong",{},[175],{"type":40,"value":176},"暫定古蹟",{"type":40,"value":178},"」。後經 3 度文資審議， 於 2021 年 9 月公告為 ",{"type":34,"tag":172,"props":180,"children":181},{},[182],{"type":40,"value":183},"歷史建築",{"type":40,"value":185},"，登錄名稱「龜山樟腦寮協和磚廠」，種類「產業及其他設施」，本體為八卦窯、煙囪，本體面積約 364.8 平方公尺，全區面積 3200 平方公尺。",{"type":34,"tag":187,"props":188,"children":190},"h4",{"id":189},"歷史建築保存的價值",[191],{"type":40,"value":192},"歷史建築保存的價值:",{"type":34,"tag":73,"props":194,"children":195},{},[196],{"type":40,"value":197},"在《文化資產保存法》考慮的歷史價值包含：",{"type":34,"tag":48,"props":199,"children":200},{},[201,206],{"type":34,"tag":52,"props":202,"children":203},{},[204],{"type":40,"value":205},"建築工法（磚窯特色、煙囪）: 目前八卦磚窯主體已經完全被破壞, 只留煙囪對建築工法的歷史保存意義不大！",{"type":34,"tag":52,"props":207,"children":208},{},[209],{"type":40,"value":210},"產業發展價值（樟腦及磚窯結合）及區域產業轉型的歷史意義: 可以在地建立紀念公園, 提供歷史圖片及文檔來彰顯。",{"type":34,"tag":187,"props":212,"children":214},{"id":213},"保存兩隻煙囪的疑慮",[215],{"type":40,"value":216},"保存兩隻煙囪的疑慮：",{"type":34,"tag":48,"props":218,"children":219},{},[220,225,230],{"type":34,"tag":52,"props":221,"children":222},{},[223],{"type":40,"value":224},"由於兩隻高大煙囪都年久失修, 又樹立於交通要道。未來在在颱風及雷擊的狀況都有安全隱患！",{"type":34,"tag":52,"props":226,"children":227},{},[228],{"type":40,"value":229},"目前桃園市府規劃的變一文學路延伸計劃中, 考量兩隻煙囪的位址採用地下通過。但因施工技術困難而一再流標。 未來道路由煙囪下通過的施工也仍有讓煙囪倒塌的疑慮！",{"type":34,"tag":52,"props":231,"children":232},{},[233,235,241],{"type":40,"value":234},"依據 A7 重劃區居民的",{"type":34,"tag":77,"props":236,"children":238},{"href":237},"https://www.facebook.com/share/p/1AwWCJFqCW/",[239],{"type":40,"value":240}," 社區意見調查",{"type":40,"value":242},", 九成的居民都讚成廢除者兩隻煙囪。 希望變一及變四案都能早日實現！",{"type":34,"tag":42,"props":244,"children":246},{"id":245},"歷史建築的法律規範",[247],{"type":40,"value":245},{"type":34,"tag":187,"props":249,"children":251},{"id":250},"什麼是歷史建築",[252],{"type":40,"value":253},"什麼是「歷史建築」？",{"type":34,"tag":73,"props":255,"children":256},{},[257],{"type":40,"value":258},"在台灣，《文化資產保存法》將「歷史建築」列為一種文化資產類型，屬於 法定文化資產，雖然保護等級不像「古蹟」那麼高，但仍然有法律保護，不能隨意拆除。",{"type":34,"tag":187,"props":260,"children":262},{"id":261},"歷史建築可以拆除的條件",[263],{"type":40,"value":261},{"type":34,"tag":73,"props":265,"children":266},{},[267],{"type":40,"value":268},"根據《文化資產保存法》第 99 條: 若屬歷史建築，原則上禁止拆除，除非「發生不可抗力因素」或「有重大公共利益需要」。",{"type":34,"tag":73,"props":270,"children":271},{},[272,274,278],{"type":40,"value":273},"🔥 不可抗力因素:",{"type":34,"tag":275,"props":276,"children":277},"br",{},[],{"type":40,"value":279},"\n例如重大地震、火災、颱風或其他天然災害，導致結構嚴重毀損，經主管機關認定已無保存價值或難以修復時，才會允許拆除。",{"type":34,"tag":73,"props":281,"children":282},{},[283,285,288],{"type":40,"value":284},"🏗️ 重大公共利益需要:",{"type":34,"tag":275,"props":286,"children":287},{},[],{"type":40,"value":289},"\n必須經過文化資產審議委員會審議通過，且確認「無其他替代方案」的情況下，才能核准拆除或移築。",{"type":34,"tag":73,"props":291,"children":292},{},[293,295,300],{"type":40,"value":294},"例子：",{"type":34,"tag":172,"props":296,"children":297},{},[298],{"type":40,"value":299},"重大交通工程",{"type":40,"value":301},"、國家重要建設需要占用該地。",{"type":34,"tag":187,"props":303,"children":305},{"id":304},"流程上需要做什麼",[306],{"type":40,"value":307},"流程上需要做什麼？",{"type":34,"tag":73,"props":309,"children":310},{},[311,313,316,318,321,323,326],{"type":40,"value":312},"1️⃣ 提出「報廢或拆除」計畫申請.",{"type":34,"tag":275,"props":314,"children":315},{},[],{"type":40,"value":317},"\n2️⃣ 由地方文化局或文化部召開審議會議.",{"type":34,"tag":275,"props":319,"children":320},{},[],{"type":40,"value":322},"\n3️⃣ 需由專家進行現勘與評估報告.",{"type":34,"tag":275,"props":324,"children":325},{},[],{"type":40,"value":327},"\n4️⃣ 若通過，主管機關會公告同意處置方案.",{"type":34,"tag":187,"props":329,"children":331},{"id":330},"歷史建築-vs-古蹟-拆除限制比較",[332],{"type":40,"value":333},"歷史建築 vs 古蹟 — 拆除限制比較",{"type":40,"value":335},"\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n",{"type":34,"tag":337,"props":338,"children":339},"table",{},[340,364],{"type":34,"tag":341,"props":342,"children":343},"thead",{},[344],{"type":34,"tag":345,"props":346,"children":347},"tr",{},[348,354,359],{"type":34,"tag":349,"props":350,"children":351},"th",{},[352],{"type":40,"value":353},"分類",{"type":34,"tag":349,"props":355,"children":356},{},[357],{"type":40,"value":358},"是否可拆",{"type":34,"tag":349,"props":360,"children":361},{},[362],{"type":40,"value":363},"條件說明",{"type":34,"tag":365,"props":366,"children":367},"tbody",{},[368,397],{"type":34,"tag":345,"props":369,"children":370},{},[371,380,385],{"type":34,"tag":372,"props":373,"children":374},"td",{},[375],{"type":34,"tag":172,"props":376,"children":377},{},[378],{"type":40,"value":379},"古蹟",{"type":34,"tag":372,"props":381,"children":382},{},[383],{"type":40,"value":384},"幾乎禁止",{"type":34,"tag":372,"props":386,"children":387},{},[388,390,395],{"type":40,"value":389},"除非因 ",{"type":34,"tag":172,"props":391,"children":392},{},[393],{"type":40,"value":394},"不可抗力因素",{"type":40,"value":396},"（如重大天然災害嚴重毀損），經主管機關認定無保存價值，否則嚴禁拆除。",{"type":34,"tag":345,"props":398,"children":399},{},[400,407,412],{"type":34,"tag":372,"props":401,"children":402},{},[403],{"type":34,"tag":172,"props":404,"children":405},{},[406],{"type":40,"value":183},{"type":34,"tag":372,"props":408,"children":409},{},[410],{"type":40,"value":411},"原則禁止",{"type":34,"tag":372,"props":413,"children":414},{},[415,417,421,423,428],{"type":40,"value":416},"除非發生 ",{"type":34,"tag":172,"props":418,"children":419},{},[420],{"type":40,"value":394},{"type":40,"value":422}," 或因 ",{"type":34,"tag":172,"props":424,"children":425},{},[426],{"type":40,"value":427},"重大公共利益需要",{"type":40,"value":429},"，且必須經審議會審議通過，確認無替代方案後才可拆除或遷移保存。",{"title":7,"searchDepth":431,"depth":431,"links":432},2,[433],{"id":37,"depth":431,"text":8,"children":434},[435,437,438,439],{"id":44,"depth":436,"text":44},3,{"id":137,"depth":436,"text":137},{"id":155,"depth":436,"text":155},{"id":245,"depth":436,"text":245},"markdown","content:construction:c31.md","content","construction/c31.md","md",1775809022467]