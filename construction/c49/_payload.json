[{"data":1,"prerenderedAt":359},["Reactive",2],{"content-query-epFl2e8vYz":3},{"_path":4,"_dir":5,"_draft":6,"_partial":6,"_locale":7,"title":8,"description":9,"image":10,"sequence":11,"category":12,"status":13,"type":9,"budget":14,"link":9,"head":15,"publishedAt":29,"toc":30,"body":31,"_type":354,"_id":355,"_source":356,"_file":357,"_extension":358},"/construction/c49","construction",false,"","桃園文青再生水計畫 - 公滯六",null,"/images/construction/c42-1.jpg",49,"工商發展","2.施工","12.4 億",{"meta":16},[17,19,21,23,26],{"name":18,"content":7},"keywords",{"name":20,"content":7},"robots",{"name":22,"content":7},"author",{"name":24,"content":25},"copyright","© 2024 A7新林口-社區網站",{"name":27,"content":28},"og:title","地方行政","2027-06-30T00:00:00.000Z",true,{"type":32,"children":33,"toc":346},"root",[34,42,48,92,97,109,114,119,124,133,156,168,173,178,183,206,217,222,227,245,258,278,290,295,300,305,310,315,320,328,333],{"type":35,"tag":36,"props":37,"children":39},"element","h2",{"id":38},"桃園文青再生水計畫-公滯六",[40],{"type":41,"value":8},"text",{"type":35,"tag":43,"props":44,"children":46},"h3",{"id":45},"計畫概要",[47],{"type":41,"value":45},{"type":35,"tag":49,"props":50,"children":51},"ul",{},[52,58,63,68,73,78],{"type":35,"tag":53,"props":54,"children":55},"li",{},[56],{"type":41,"value":57},"項目 公滯六： 再生水廠",{"type":35,"tag":53,"props":59,"children":60},{},[61],{"type":41,"value":62},"類別 居住環境 - CON-49",{"type":35,"tag":53,"props":64,"children":65},{},[66],{"type":41,"value":67},"日期 預計 2027 年上半年完工啟用",{"type":35,"tag":53,"props":69,"children":70},{},[71],{"type":41,"value":72},"經費 再生水廠總經費 8.53 億 （中央 7.85億 地方 0.68 億）",{"type":35,"tag":53,"props":74,"children":75},{},[76],{"type":41,"value":77},"狀態 已決標",{"type":35,"tag":53,"props":79,"children":80},{},[81,83,90],{"type":41,"value":82},"計畫書 ",{"type":35,"tag":84,"props":85,"children":87},"a",{"href":86},"https://www.nlma.gov.tw/uploads/files/ffd58d929be2c437d5bc7245d8b8cf32.pdf?fbclid=IwY2xjawLsDdNleHRuA2FlbQIxMABicmlkETFaUTZDcG9RVkVLdjlYZzRJAR5IJiNXbeHrcP8p7msX0V6oMiC19zvc-WD1AfU0953FsPtHIICGXH1QifVI8w_aem_e1rANvbNlxcMRMQkPW318A",[88],{"type":41,"value":89},"公共污水處理廠再生水推動計劃",{"type":41,"value":91}," 110 至 115 年度 (66-67 頁)",{"type":35,"tag":43,"props":93,"children":95},{"id":94},"計劃詳情",[96],{"type":41,"value":94},{"type":35,"tag":98,"props":99,"children":100},"p",{},[101,107],{"type":35,"tag":84,"props":102,"children":104},{"href":103},"https://tw.news.yahoo.com/%E9%BE%9C%E5%B1%B1-%E6%96%87%E9%9D%92%E5%86%8D%E7%94%9F%E6%B0%B4%E4%B8%AD%E5%BF%83%E5%8B%95%E5%9C%9F-%E4%BE%9B%E8%8F%AF%E4%BA%9E%E7%A7%91%E7%94%A8%E6%B0%B4-201000145.html?guccounter=1&guce_referrer=aHR0cHM6Ly93d3cuZ29vZ2xlLmNvbS8&guce_referrer_sig=AQAAAGIem3cMx6iqLwplCwhtlP3G8yIqnUe_ALvSKfqkzFv4WE2q57UG7gBJl7-_aT3VqIcd9Eg-SCFtu7AgljNNHHc-IWJOuCwv47mL8tjMg2uzp7-S3_RzRn23zMfpJNJXxZOz7JsBxxU5y8Tbxh73VMn7mkLz6_8vFbynYjEuAeCB",[105],{"type":41,"value":106},"Yahoo! 新聞 2026/01/31",{"type":41,"value":108},":",{"type":35,"tag":98,"props":110,"children":111},{},[112],{"type":41,"value":113},"文青水園再生水中心30日動土，首期工程預計明年底完工，可提供5300噸工業再生水至華亞科學園區。",{"type":35,"tag":98,"props":115,"children":116},{},[117],{"type":41,"value":118},"桃園市水務局說，該再生水廠設計理念是地下產水，地上則是公園，延續原本就有的「環型滯洪池」核心概念，建物將有夜間光雕，園區內有活動大草坪、遊憩共融空間，可以提供高品質的再生水給科技園區，也能澆灌鄰近的高爾夫球場。",{"type":35,"tag":98,"props":120,"children":121},{},[122],{"type":41,"value":123},"水務局補充，文青水園再生水廠有規畫第2期工程，估計可供應每日1萬600噸再生水，但期程尚未確定，主要是需配合A7人口入住狀況，人口夠多才有足夠的生活汙水給水資源中心，再供應排放水給再生水廠。",{"type":35,"tag":98,"props":125,"children":126},{},[127],{"type":35,"tag":128,"props":129,"children":132},"img",{"alt":130,"src":131},"c49-11.jpeg","/images/construction/c49-11.jpeg",[],{"type":35,"tag":98,"props":134,"children":135},{},[136,141,146,151],{"type":35,"tag":128,"props":137,"children":140},{"alt":138,"src":139},"c49-13.jpeg","/images/construction/c49-13.jpeg",[],{"type":35,"tag":128,"props":142,"children":145},{"alt":143,"src":144},"c49-14.jpeg","/images/construction/c49-14.jpeg",[],{"type":35,"tag":128,"props":147,"children":150},{"alt":148,"src":149},"c49-15.jpeg","/images/construction/c49-15.jpeg",[],{"type":35,"tag":128,"props":152,"children":155},{"alt":153,"src":154},"c49-16.jpeg","/images/construction/c49-16.jpeg",[],{"type":35,"tag":98,"props":157,"children":158},{},[159,161,167],{"type":41,"value":160},"Facebook ",{"type":35,"tag":84,"props":162,"children":164},{"href":163},"https://www.facebook.com/share/p/1SGXRvi7Hf/",[165],{"type":41,"value":166},"桃園市水務局 2026/01/28",{"type":41,"value":108},{"type":35,"tag":98,"props":169,"children":170},{},[171],{"type":41,"value":172},"#桃園文青再生水計畫 第一期工程決標 ‼️\n預計 2027 年完工並開始供水 🏭 初期每日可產 5,300 噸再生水並已獲得 #台灣美光晶圓 與 #穩懋半導體 購水意向相當於桃園市近 2 萬人的一天用水量 💦",{"type":35,"tag":98,"props":174,"children":175},{},[176],{"type":41,"value":177},"文青再生水廠地面規劃為綠地兼滯洪池平時提供市民朋友遊憩休閒颱風或豪雨時，也能發揮 #防洪功能守護大家的安全",{"type":35,"tag":98,"props":179,"children":180},{},[181],{"type":41,"value":182},"未來二期工程完成後日產能將擴大至每日 1.06 萬噸 📈持續穩定產業用水、提升城市供水韌性為城市永續注入全新力量！",{"type":35,"tag":98,"props":184,"children":185},{},[186,191,196,201],{"type":35,"tag":128,"props":187,"children":190},{"alt":188,"src":189},"c49-04.jpeg","/images/construction/c49-04.jpeg",[],{"type":35,"tag":128,"props":192,"children":195},{"alt":193,"src":194},"c49-10.jpeg","/images/construction/c49-10.jpeg",[],{"type":35,"tag":128,"props":197,"children":200},{"alt":198,"src":199},"c49-08.jpeg","/images/construction/c49-08.jpeg",[],{"type":35,"tag":128,"props":202,"children":205},{"alt":203,"src":204},"c49-09.jpeg","/images/construction/c49-09.jpeg",[],{"type":35,"tag":98,"props":207,"children":208},{},[209,215],{"type":35,"tag":84,"props":210,"children":212},{"href":211},"https://udn.com/news/story/7324/8993500",[213],{"type":41,"value":214},"聯合新聞網 2025/09/09",{"type":41,"value":216},": 桃園13億再生水系統未建先轟動 2科技大廠已洽詢買水",{"type":35,"tag":98,"props":218,"children":219},{},[220],{"type":41,"value":221},"桃園近年科技業發達，吸引外地人口移入，但產業與人口雙成長也使得用水需求增加。為避免經濟與民生「搶水」衝突，市府啟動文青水資源中心再生水計畫，滿足產業用水需求，第一期工程 2025/09/09公告決標，預計2027年完工，5300噸再生水將先供應台灣美光晶圓與穩懋半導體2家公司。",{"type":35,"tag":98,"props":223,"children":224},{},[225],{"type":41,"value":226},"桃園市水務局指出，桃園工業產值連續9年居全國之首，近年由於各項建設陸續推動，更吸引大量人口與產業進入，使民生及工業用水需求不斷增加。然而，受到極端氣候影響，枯水時期頻率增加也增長，嚴重影響桃園地區調度用水。為維持經濟產業與民生供需平衡，求得長期穩定發展，穩定供給的水源至關重要，因此積極辦理再生水計畫。",{"type":35,"tag":98,"props":228,"children":229},{},[230,235,240],{"type":35,"tag":128,"props":231,"children":234},{"alt":232,"src":233},"c49-05.jpeg","/images/construction/c49-05.jpeg",[],{"type":35,"tag":128,"props":236,"children":239},{"alt":237,"src":238},"c49-06.jpeg","/images/construction/c49-06.jpeg",[],{"type":35,"tag":128,"props":241,"children":244},{"alt":242,"src":243},"c49-07.jpeg","/images/construction/c49-07.jpeg",[],{"type":35,"tag":98,"props":246,"children":247},{},[248,250,256],{"type":41,"value":249},"Facebook: ",{"type":35,"tag":84,"props":251,"children":253},{"href":252},"https://www.facebook.com/groups/a7xinlinkou/posts/986095366829045/?comment_id=986164486822133",[254],{"type":41,"value":255},"Aileen Yeh 2025/07/22",{"type":41,"value":257},": 感謝網友的說明！",{"type":35,"tag":98,"props":259,"children":260},{},[261,263,269,271,276],{"type":41,"value":262},"該案的設計概念為：配合環型步道及建築外觀展開的空間，從室內延續到戶外開放空間，結合成一體，塑造一個集中性聚焦式的廣場設計，",{"type":35,"tag":264,"props":265,"children":266},"strong",{},[267],{"type":41,"value":268},"在細節的設計上增加公共藝術，遮陽空間、小型球場等特色休閒",{"type":41,"value":270},"，配置於原滯洪池底部， 增加留客元素，",{"type":35,"tag":264,"props":272,"children":273},{},[274],{"type":41,"value":275},"原環型步道種植大型喬木，斜坡可植草皮，做為居民日常休憩空間",{"type":41,"value":277},"。",{"type":35,"tag":98,"props":279,"children":280},{},[281,283,289],{"type":41,"value":282},"自由時報 2023/11/02 ",{"type":35,"tag":84,"props":284,"children":286},{"href":285},"https://ec.ltn.com.tw/amp/article/breakingnews/4477587?fbclid=IwY2xjawLsDk9leHRuA2FlbQIxMABicmlkETFaUTZDcG9RVkVLdjlYZzRJAR6SEGIPzBLeDjKEfU-RLENVYlpfJ9RTGbtj3ioauG8rtTQyvUQM6t6sfoqTCQ_aem_Ok-QF7XGIA1PY_xPFAkmmw",[287],{"type":41,"value":288},"桃園文青再生水計畫 2026 年日供華亞科技園區 5300 噸",{"type":41,"value":108},{"type":35,"tag":98,"props":291,"children":292},{},[293],{"type":41,"value":294},"桃市府推動水資源回收再利用，在內政部國土管理署支持下，桃園文青水園水資源中心再生水計畫順利推動，且已與華亞科技園區簽訂用水契約，再生水廠預計 2026 年完工啟用，屆時每日可供 5300 噸再生水，透過地方與中央聯手解決企業降低缺水風險。",{"type":35,"tag":98,"props":296,"children":297},{},[298],{"type":41,"value":299},"水務局表示，市府於 2021 年開始籌辦桃園文青水園水資源中心再生水計畫，過程中對於園區內外設施界面、水價及用水契約，遲遲無法取得共識，在與用水端歷經多次討論後，成功整合華亞科技園區、台灣美光晶圓科技股份有限公司與穩懋半導體股份有限公司達成共識。",{"type":35,"tag":98,"props":301,"children":302},{},[303],{"type":41,"value":304},"水務局表示，計畫也爭取到國土管理署經費補助，全期建設總經費為 12.4 億元，第 1 期每日產水 5300 噸再生水，全期可擴充至每日產水 1 萬 0600 噸，營運期 15 年、總供水量約 3178 萬立方公尺，相當省下 1 萬 2712 座奧林匹克標準泳池水量，總售水效益達 7.4 億元。",{"type":35,"tag":98,"props":306,"children":307},{},[308],{"type":41,"value":309},"水務局表示，再生水計畫可增加水資源調度彈性，大幅降低缺水風險，如同打造「都市小水庫」，產業有穩定水源使用，更能吸引廠商進駐，達到「民生不停供、工業不停工」目標。",{"type":35,"tag":98,"props":311,"children":312},{},[313],{"type":41,"value":314},"水務局長劉振宇表示，鼓勵企業多使用再生水，減輕桃園地區用水壓力，提升桃園地區水資源調度彈性，降低產業用水風險。",{"type":35,"tag":98,"props":316,"children":317},{},[318],{"type":41,"value":319},"此外，為有效利用水資源，桃市府擴大使用放流水用途與範圍，除開放機關及民眾免費申請取用回作為浴廁沖洗、公共環境清潔用水、綠地景觀澆灌及路面洗地灑水等用途，更創全國之先，運用公共民生水資源回收中心放流水作為農業灌溉用水，把經過水資源回收中心處理過後的家庭污水放流水做為農業灌溉用水，讓珍貴水資源有效再運用。",{"type":35,"tag":98,"props":321,"children":322},{},[323],{"type":35,"tag":128,"props":324,"children":327},{"alt":325,"src":326},"c49-01.jpeg","/images/construction/c49-01.jpeg",[],{"type":35,"tag":98,"props":329,"children":330},{},[331],{"type":41,"value":332},"桃園文青水園水資源中心再生水計劃再生水廠 示意圖",{"type":35,"tag":98,"props":334,"children":335},{},[336,341],{"type":35,"tag":128,"props":337,"children":340},{"alt":338,"src":339},"c49-02.jpeg","/images/construction/c49-02.jpeg",[],{"type":35,"tag":128,"props":342,"children":345},{"alt":343,"src":344},"c49-03.jpeg","/images/construction/c49-03.jpeg",[],{"title":7,"searchDepth":347,"depth":347,"links":348},2,[349],{"id":38,"depth":347,"text":8,"children":350},[351,353],{"id":45,"depth":352,"text":45},3,{"id":94,"depth":352,"text":94},"markdown","content:construction:c49.md","content","construction/c49.md","md",1773642135122]