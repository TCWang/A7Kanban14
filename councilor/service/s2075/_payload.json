[{"data":1,"prerenderedAt":76},["Reactive",2],{"content-query-lzRM4zxDOr":3},{"_path":4,"_dir":5,"_draft":6,"_partial":6,"_locale":7,"title":8,"description":9,"image":10,"sequence":11,"category1":12,"category2":13,"link":14,"author":15,"head":16,"publishedAt":30,"toc":31,"body":32,"_type":71,"_id":72,"_source":73,"_file":74,"_extension":75},"/councilor/service/s2075","service",false,"","華亞三路與文化一路口｜改善行人穿越動線",null,"/images/service/s2075-1.jpeg",2075,"A. 健全都市發展","A.1 加速宜居城市建設","https://www.facebook.com/share/p/1AEDKR1pbJ/","李宗豪",{"meta":17},[18,20,22,24,27],{"name":19,"content":7},"keywords",{"name":21,"content":7},"robots",{"name":23,"content":15},"author",{"name":25,"content":26},"copyright","© 2024 A7新林口-社區網站",{"name":28,"content":29},"og:title","地方行政","2025-12-04T00:00:00.000Z",true,{"type":33,"children":34,"toc":67},"root",[35,43,49,54,59],{"type":36,"tag":37,"props":38,"children":40},"element","h2",{"id":39},"華亞三路與文化一路口改善行人穿越動線",[41],{"type":42,"value":8},"text",{"type":36,"tag":44,"props":45,"children":46},"p",{},[47],{"type":42,"value":48},"華亞三路左轉文化一路路口，因捷運樑柱造成視線遮蔽，左轉車輛無法及時看見行穿線上的行人，影響行人通行安全，此處也是樂善國小的通學路線。",{"type":36,"tag":44,"props":50,"children":51},{},[52],{"type":42,"value":53},"宗豪與黃錦芳里長及相關單位會勘後，決議透過分隔島工程調整行穿線位置，將行穿線適度退縮，確保車輛左轉後能立即看見行人，並提升駕駛反應距離與行人保護空間。",{"type":36,"tag":44,"props":55,"children":56},{},[57],{"type":42,"value":58},"感謝交通局、養工處、桃園捷運公司及樂善國小，我們會持續關注通行的狀況，希望學生與行人安全更加完善 💪🏻",{"type":36,"tag":44,"props":60,"children":61},{},[62],{"type":36,"tag":63,"props":64,"children":66},"img",{"alt":65,"src":10},"s2075-1.jpeg",[],{"title":7,"searchDepth":68,"depth":68,"links":69},2,[70],{"id":39,"depth":68,"text":8},"markdown","content:councilor:service:s2075.md","content","councilor/service/s2075.md","md",1775809027348]