[{"data":1,"prerenderedAt":1560},["Reactive",2],{"content-query-aE8OdZf3t1":3},{"_path":4,"_dir":5,"_draft":6,"_partial":6,"_locale":7,"title":8,"description":9,"image":10,"ogImage":11,"sequence":12,"category":13,"place":14,"author":15,"head":16,"publishedAt":30,"toc":31,"body":32,"_type":1555,"_id":1556,"_source":1557,"_file":1558,"_extension":1559},"/resident/r052","resident",false,"","打造「龜山 動物共生轉運站」示範計畫",null,"/images/resident/r052-01.jpeg","https://a7kanban14.netlify.app/images/resident/r052-01.jpeg",52,"動物保護","A7重劃區","社區網站",{"meta":17},[18,20,22,24,27],{"name":19,"content":7},"keywords",{"name":21,"content":7},"robots",{"name":23,"content":7},"author",{"name":25,"content":26},"copyright","© 2025 ",{"name":28,"content":29},"og:title","社區網站-地方行政","2025-11-20T00:00:00.000Z",true,{"type":33,"children":34,"toc":1532},"root",[35,44,50,63,68,77,86,92,97,102,108,120,126,147,189,195,207,214,233,267,273,290,353,359,375,416,421,433,443,448,453,458,470,476,636,640,646,658,668,681,690,715,724,744,753,780,786,798,833,839,858,864,904,910,937,943,977,980,985,991,999,1010,1018,1041,1049,1069,1072,1078,1086,1097,1104,1144,1151,1166,1169,1175,1183,1188,1196,1256,1263,1278,1281,1287,1295,1300,1307,1330,1337,1359,1365,1375,1385,1393,1488,1495],{"type":36,"tag":37,"props":38,"children":40},"element","h2",{"id":39},"提案名稱打造龜山-動物共生轉運站示範計畫",[41],{"type":42,"value":43},"text","提案名稱：打造「龜山 動物共生轉運站」示範計畫",{"type":36,"tag":45,"props":46,"children":48},"h3",{"id":47},"緣起",[49],{"type":42,"value":47},{"type":36,"tag":51,"props":52,"children":53},"p",{},[54,61],{"type":36,"tag":55,"props":56,"children":58},"a",{"href":57},"https://www.facebook.com/share/p/1NBanoQ87p/",[59],{"type":42,"value":60},"#A7 新林口-社區網站 2025/11/13",{"type":42,"value":62},": 黑狗四兄弟的貼文, 在一周內就有近一萬次的點擊率, 顯示出 A7 重劃區居民對於流浪犬貓問題的高度關注與期待解決方案。",{"type":36,"tag":51,"props":64,"children":65},{},[66],{"type":42,"value":67},"本文是希望能為黑狗四兄弟, 建請桃園市政府/ 龜山區公所及所有龜山區議員們！ 建立龜山 動物共生轉運站 示範計畫！ 也請所有熱心居民一起來支持本案的推動。",{"type":36,"tag":51,"props":69,"children":70},{},[71],{"type":36,"tag":72,"props":73,"children":76},"img",{"alt":74,"src":75},"r052-02.jpeg","/images/resident/r052-02.jpeg",[],{"type":36,"tag":51,"props":78,"children":79},{},[80],{"type":36,"tag":81,"props":82,"children":83},"strong",{},[84],{"type":42,"value":85},"A7 的流浪動物現況",{"type":36,"tag":72,"props":87,"children":91},{"src":88,"alt":89,"width":90,"height":90},"/images/resident/r052-14.jpeg","r052-14.jpeg",100,[],{"type":36,"tag":72,"props":93,"children":96},{"src":94,"alt":95,"width":90,"height":90},"/images/resident/r052-13.jpeg","r052-13.jpeg",[],{"type":36,"tag":72,"props":98,"children":101},{"src":99,"alt":100,"width":90,"height":90},"/images/resident/r052-15.jpeg","r052-15.jpeg",[],{"type":36,"tag":45,"props":103,"children":105},{"id":104},"一-主旨",[106],{"type":42,"value":107},"一、 主旨",{"type":36,"tag":51,"props":109,"children":110},{},[111,113,118],{"type":42,"value":112},"建請 桃園市政府（及龜山區公所）參考「南昌動物保護教育園區」之成功模式，於龜山 A7 重劃區設立 ",{"type":36,"tag":81,"props":114,"children":115},{},[116],{"type":42,"value":117},"「小型化、社區化、中途化」的「A7 動物共生轉運站」",{"type":42,"value":119},"。旨在解決重劃區工地流浪犬貓問題，並結合國際「中途寄養」與「飼主教育」制度，將此據點打造為結合公園綠地、認養轉運與生命教育的多功能場域，而非傳統嫌惡設施。",{"type":36,"tag":45,"props":121,"children":123},{"id":122},"二-說明",[124],{"type":42,"value":125},"二、 說明",{"type":36,"tag":51,"props":127,"children":128},{},[129,134,136,140,145],{"type":36,"tag":81,"props":130,"children":131},{},[132],{"type":42,"value":133},"區域特性與急迫性：",{"type":42,"value":135}," A7 重劃區人口激增，年輕家庭眾多，但周邊仍存有大量建築工地與山坡荒地，易聚集遊蕩犬隻，造成人犬衝突（追車、噪音）。現有收容所（新屋）距離過遠，緩不濟急；南昌園區雖在桃園區，但無法即時覆蓋龜山台地之需求。",{"type":36,"tag":137,"props":138,"children":139},"br",{},[],{"type":36,"tag":81,"props":141,"children":142},{},[143],{"type":42,"value":144},"借鏡「南昌模式」與「國際經驗」：",{"type":42,"value":146},".",{"type":36,"tag":148,"props":149,"children":150},"ul",{},[151,162,172],{"type":36,"tag":152,"props":153,"children":154},"li",{},[155,160],{"type":36,"tag":81,"props":156,"children":157},{},[158],{"type":42,"value":159},"桃園市南昌園區模式：",{"type":42,"value":161}," 證明「市區型園區」可行，透過結合醫療、公園與明亮設計，能提高認養率並降低鄰避效應。",{"type":36,"tag":152,"props":163,"children":164},{},[165,170],{"type":36,"tag":81,"props":166,"children":167},{},[168],{"type":42,"value":169},"美國奧斯汀模式：",{"type":42,"value":171}," 證明「中途家庭（Foster）」能取代大型收容籠舍。A7 擁有大量喜愛動物的年輕住戶，是發展社區保母網絡的最佳實驗場。",{"type":36,"tag":152,"props":173,"children":174},{},[175,180,182,187],{"type":36,"tag":81,"props":176,"children":177},{},[178],{"type":42,"value":179},"德國柏林模式：",{"type":42,"value":181}," 強調「飼主教育」，源頭減少棄養。\n",{"type":36,"tag":81,"props":183,"children":184},{},[185],{"type":42,"value":186},"預期效益：",{"type":42,"value":188}," 有效控制 A7 區域遊蕩犬貓數量、提升社區居住品質、建立桃園市第二個「都會型動保標竿」。",{"type":36,"tag":45,"props":190,"children":192},{"id":191},"三-辦法分短中長期執行",[193],{"type":42,"value":194},"三、 辦法（分短、中、長期執行）",{"type":36,"tag":51,"props":196,"children":197},{},[198,200,205],{"type":42,"value":199},"本計畫建議不蓋大型水泥建築，而是利用",{"type":36,"tag":81,"props":201,"children":202},{},[203],{"type":42,"value":204},"組合屋、貨櫃屋設計結合綠地",{"type":42,"value":206},"，強調靈活與低成本，分階段推動：",{"type":36,"tag":208,"props":209,"children":211},"h4",{"id":210},"短期規劃精準熱點打擊與中途網絡建置0-1-年",[212],{"type":42,"value":213},"【短期規劃：精準熱點打擊與「中途網絡」建置】（0-1 年）",{"type":36,"tag":51,"props":215,"children":216},{},[217,222,224,227,232],{"type":36,"tag":81,"props":218,"children":219},{},[220],{"type":42,"value":221},"目標：",{"type":42,"value":223}," 快速降低街頭遊蕩犬數量，緩解居民恐慌。",{"type":36,"tag":137,"props":225,"children":226},{},[],{"type":36,"tag":81,"props":228,"children":229},{},[230],{"type":42,"value":231},"具體執行：",{"type":42,"value":146},{"type":36,"tag":234,"props":235,"children":236},"ol",{},[237,247,257],{"type":36,"tag":152,"props":238,"children":239},{},[240,245],{"type":36,"tag":81,"props":241,"children":242},{},[243],{"type":42,"value":244},"無人機熱點普查（科技動保）：",{"type":42,"value":246}," 比照桃園市府現有技術，利用無人機偵測 A7 周邊工地與草叢的犬隻聚集熱點，建立「A7 遊蕩犬地圖」。",{"type":36,"tag":152,"props":248,"children":249},{},[250,255],{"type":36,"tag":81,"props":251,"children":252},{},[253],{"type":42,"value":254},"推動「工地守衛犬」計畫（源頭管理）：",{"type":42,"value":256}," 與建商合作，將工地流浪犬絕育、施打疫苗後，原地納管為工地守衛犬，工程結束後由政府協助媒合認養，避免工程結束後狗群被棄置。",{"type":36,"tag":152,"props":258,"children":259},{},[260,265],{"type":36,"tag":81,"props":261,"children":262},{},[263],{"type":42,"value":264},"建立「A7 雲端中途網」（參照美國模式）：",{"type":42,"value":266}," 不急著蓋欄舍，而是由區公所主導，招募 A7 社區的愛心住戶成為「短期中途家庭」。政府提供飼料與醫療補助（如南昌園區支援醫療），將溫馴犬貓交由家庭暫養，而非送往新屋，增加社會化與曝光度。",{"type":36,"tag":208,"props":268,"children":270},{"id":269},"中期規劃設立a7-共生轉運站實體據點1-3-年",[271],{"type":42,"value":272},"【中期規劃：設立「A7 共生轉運站」實體據點】（1-3 年）",{"type":36,"tag":51,"props":274,"children":275},{},[276,280,282,285,289],{"type":36,"tag":81,"props":277,"children":278},{},[279],{"type":42,"value":221},{"type":42,"value":281}," 建立實體地標，作為醫療、教育與認養的社區中心。",{"type":36,"tag":137,"props":283,"children":284},{},[],{"type":36,"tag":81,"props":286,"children":287},{},[288],{"type":42,"value":231},{"type":42,"value":146},{"type":36,"tag":234,"props":291,"children":292},{},[293,333,343],{"type":36,"tag":152,"props":294,"children":295},{},[296,301,303,308,310],{"type":36,"tag":81,"props":297,"children":298},{},[299],{"type":42,"value":300},"選址與建設（參照桃園南昌模式）：",{"type":42,"value":302}," 盤點 A7 內的公園預定地或閒置公有地，設置小規模的 ",{"type":36,"tag":81,"props":304,"children":305},{},[306],{"type":42,"value":307},"「貨櫃市集風」轉運站",{"type":42,"value":309},"。\n",{"type":36,"tag":148,"props":311,"children":312},{},[313,323],{"type":36,"tag":152,"props":314,"children":315},{},[316,321],{"type":36,"tag":81,"props":317,"children":318},{},[319],{"type":42,"value":320},"功能：",{"type":42,"value":322}," 含簡易醫療室（絕育/急救）、小規模貓屋、犬隻互動草皮。",{"type":36,"tag":152,"props":324,"children":325},{},[326,331],{"type":36,"tag":81,"props":327,"children":328},{},[329],{"type":42,"value":330},"外觀：",{"type":42,"value":332}," 需具設計感，結合咖啡座或親子遊憩區，消除「鄰避設施」印象。",{"type":36,"tag":152,"props":334,"children":335},{},[336,341],{"type":36,"tag":81,"props":337,"children":338},{},[339],{"type":42,"value":340},"導入「德國式」飼主責任課程：",{"type":42,"value":342}," 規定凡是在此認養的民眾，需接受 2-3 小時的飼主責任教育（可由合作的訓犬師或志工授課），完成後給予「優良飼主卡」，在龜山區合作寵物店消費享有折扣。",{"type":36,"tag":152,"props":344,"children":345},{},[346,351],{"type":36,"tag":81,"props":347,"children":348},{},[349],{"type":42,"value":350},"社區巡迴醫療車：",{"type":42,"value":352}," 定期由南昌園區或合作獸醫派駐巡迴醫療車至此，提供區域內寵物與浪犬的免費絕育與疫苗服務。",{"type":36,"tag":208,"props":354,"children":356},{"id":355},"長期規劃生態平衡與零流浪示範區3-5-年",[357],{"type":42,"value":358},"【長期規劃：生態平衡與「零流浪」示範區】（3-5 年）",{"type":36,"tag":51,"props":360,"children":361},{},[362,366,368,371],{"type":36,"tag":81,"props":363,"children":364},{},[365],{"type":42,"value":221},{"type":42,"value":367}," 達成區域內無主遊蕩犬貓歸零，人類與生態和諧共存。",{"type":36,"tag":137,"props":369,"children":370},{},[],{"type":36,"tag":81,"props":372,"children":373},{},[374],{"type":42,"value":231},{"type":36,"tag":148,"props":376,"children":377},{},[378,396,406],{"type":36,"tag":152,"props":379,"children":380},{},[381,386,388],{"type":36,"tag":81,"props":382,"children":383},{},[384],{"type":42,"value":385},"劃定「生態敏感緩衝區」（參照澳洲模式）：",{"type":42,"value":387}," 針對 A7 連接山區（靠近體育大學、林口保護區）的邊界，劃定禁止餵食與禁止回置（No TNR）區域，保護原生野生動物，避免犬隻入山獵殺。請參考 ",{"type":36,"tag":55,"props":389,"children":393},{"href":390,"rel":391},"https://ourisland.pts.org.tw/content/10151",[392],"nofollow",[394],{"type":42,"value":395},"遊蕩犬貓對野生動物造成哪些衝擊？",{"type":36,"tag":152,"props":397,"children":398},{},[399,404],{"type":36,"tag":81,"props":400,"children":401},{},[402],{"type":42,"value":403},"轉型為「生命教育中心」：",{"type":42,"value":405}," 當流浪動物數量受控後，此轉運站轉型為學校校外教學基地，推廣動物福利教育。",{"type":36,"tag":152,"props":407,"children":408},{},[409,414],{"type":36,"tag":81,"props":410,"children":411},{},[412],{"type":42,"value":413},"數據化管理：",{"type":42,"value":415}," 建立 A7 寵物戶口普查大數據，完全落實寵物登記，目標成為全桃園第一個「晶片覆蓋率 100%」的示範重劃區。",{"type":36,"tag":45,"props":417,"children":419},{"id":418},"結語",[420],{"type":42,"value":418},{"type":36,"tag":51,"props":422,"children":423},{},[424,426,431],{"type":42,"value":425},"龜山 A7 擁有最新的城市面貌與高素質人口，具備極佳條件成為 ",{"type":36,"tag":81,"props":427,"children":428},{},[429],{"type":42,"value":430},"「新一代動保政策」的實驗場",{"type":42,"value":432},"。透過建立「A7 動物共生轉運站」，不僅能解決眼前的流浪動物問題，更能為桃園市打造一個結合科技、人文與生態的宜居亮點。",{"type":36,"tag":51,"props":434,"children":435},{},[436,438],{"type":42,"value":437},"A7 共生轉運站：範例\n",{"type":36,"tag":72,"props":439,"children":442},{"alt":440,"src":441},"r052-16.jpeg","/images/resident/r052-16.jpeg",[],{"type":36,"tag":37,"props":444,"children":446},{"id":445},"附件說明",[447],{"type":42,"value":445},{"type":36,"tag":37,"props":449,"children":451},{"id":450},"國內做法整理",[452],{"type":42,"value":450},{"type":36,"tag":45,"props":454,"children":456},{"id":455},"桃園市南昌動物保護教育園區",[457],{"type":42,"value":455},{"type":36,"tag":51,"props":459,"children":460},{},[461,463,468],{"type":42,"value":462},"這座園區於 2024 年底新啟用，最大的特色是位於",{"type":36,"tag":81,"props":464,"children":465},{},[466],{"type":42,"value":467},"桃園市中心",{"type":42,"value":469},"（原南昌營區），讓市民不用跑到偏遠的海邊（新屋收容所）就能認養犬貓或使用醫療資源，是目前桃園推動「智慧動保」的核心據點。",{"type":36,"tag":208,"props":471,"children":473},{"id":472},"園區基本資訊",[474],{"type":42,"value":475},"📍 園區基本資訊",{"type":36,"tag":148,"props":477,"children":478},{},[479,489,508,518,558],{"type":36,"tag":152,"props":480,"children":481},{},[482,487],{"type":36,"tag":81,"props":483,"children":484},{},[485],{"type":42,"value":486},"名稱：",{"type":42,"value":488}," 桃園市南昌動物保護教育園區（含犬貓市區認領養中心）",{"type":36,"tag":152,"props":490,"children":491},{},[492,497,499,506],{"type":36,"tag":81,"props":493,"children":494},{},[495],{"type":42,"value":496},"地址：",{"type":42,"value":498}," ",{"type":36,"tag":55,"props":500,"children":503},{"href":501,"rel":502},"https://www.google.com/search?q=https://maps.google.com/%3Fq%3D%E6%A1%83%E5%9C%92%E5%B8%82%E6%A1%83%E5%9C%92%E5%8D%80%E5%90%91%E5%96%84%E8%A1%97120-1%E8%99%9F",[392],[504],{"type":42,"value":505},"桃園市桃園區向善街 120-1 號",{"type":42,"value":507},"（原南昌營區，鄰近桃園區公所）",{"type":36,"tag":152,"props":509,"children":510},{},[511,516],{"type":36,"tag":81,"props":512,"children":513},{},[514]