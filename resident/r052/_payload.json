pe":36,"tag":208,"props":905,"children":907},{"id":906},"_2-tcap街貓友善照護行動方案社區共存",[908],{"type":42,"value":909},"2. TCAP（街貓友善照護行動方案）：社區共存",{"type":36,"tag":148,"props":911,"children":912},{},[913,928],{"type":36,"tag":152,"props":914,"children":915},{},[916,920,922,927],{"type":36,"tag":81,"props":917,"children":918},{},[919],{"type":42,"value":874},{"type":42,"value":921}," 這是比一般 TNR（捕捉、絕育、回置）更進階的模式。強調 ",{"type":36,"tag":81,"props":923,"children":924},{},[925],{"type":42,"value":926},"「里長與志工」的在地管理",{"type":42,"value":883},{"type":36,"tag":152,"props":929,"children":930},{},[931,935],{"type":36,"tag":81,"props":932,"children":933},{},[934],{"type":42,"value":891},{"type":42,"value":936}," 絕育後的街貓由社區志工造冊管理、定點餵食。這解決了「貓不知道是誰的」以及「餵食造成髒亂」的問題。讓街貓從「鄰避嫌惡物」變成「社區的一份子（甚至具有滅鼠功能）」。",{"type":36,"tag":208,"props":938,"children":940},{"id":939},"_3-動物友善空間認證生活圈的融合",[941],{"type":42,"value":942},"3. 動物友善空間認證：生活圈的融合",{"type":36,"tag":148,"props":944,"children":945},{},[946,962],{"type":36,"tag":152,"props":947,"children":948},{},[949,953,955,960],{"type":36,"tag":81,"props":950,"children":951},{},[952],{"type":42,"value":874},{"type":42,"value":954}," 推動「",{"type":36,"tag":81,"props":956,"children":957},{},[958],{"type":42,"value":959},"動物友善空間",{"type":42,"value":961},"」標章，涵蓋餐廳、計程車、旅館甚至辦公室。",{"type":36,"tag":152,"props":963,"children":964},{},[965,969,971,976],{"type":36,"tag":81,"props":966,"children":967},{},[968],{"type":42,"value":891},{"type":42,"value":970}," 這是「軟實力」的極致表現。政府制定標準（如是否可落地、有無提供水碗），合格店家可獲認證。這創造了一種社會氛圍：",{"type":36,"tag":81,"props":972,"children":973},{},[974],{"type":42,"value":975},"帶寵物出門是正常的，不需要躲躲藏藏",{"type":42,"value":883},{"type":36,"tag":637,"props":978,"children":979},{},[],{"type":36,"tag":37,"props":981,"children":983},{"id":982},"國外參考模式",[984],{"type":42,"value":982},{"type":36,"tag":45,"props":986,"children":988},{"id":987},"美國德州奧斯汀-模式強大的中途網絡取代收容所",[989],{"type":42,"value":990},"美國德州奧斯汀 模式：強大的「中途網絡」取代收容所",{"type":36,"tag":51,"props":992,"children":993},{},[994],{"type":36,"tag":81,"props":995,"children":996},{},[997],{"type":42,"value":998},"借鏡重點：解決「收容所爆籠」與「高壓環境」",{"type":36,"tag":51,"props":1000,"children":1001},{},[1002,1004,1009],{"type":42,"value":1003},"當收容所空間不足時，台灣的直覺反應是「蓋新的收容所」（鄰避效應高、成本高），但美國近年推動的 No-Kill 運動，核心在於 ",{"type":36,"tag":81,"props":1005,"children":1006},{},[1007],{"type":42,"value":1008},"「Foster Care」（中途寄養）",{"type":42,"value":883},{"type":36,"tag":51,"props":1011,"children":1012},{},[1013],{"type":36,"tag":81,"props":1014,"children":1015},{},[1016],{"type":42,"value":1017},"具體做法：",{"type":36,"tag":148,"props":1019,"children":1020},{},[1021,1031],{"type":36,"tag":152,"props":1022,"children":1023},{},[1024,1029],{"type":36,"tag":81,"props":1025,"children":1026},{},[1027],{"type":42,"value":1028},"Foster First（中途優先）：",{"type":42,"value":1030}," 收容所只是一個「轉運站」。他們建立了龐大的社區志工網，將幼貓、幼犬或需要社會化的狗，直接交給志工帶回家暫時照顧（政府或組織提供飼料與醫療費）。",{"type":36,"tag":152,"props":1032,"children":1033},{},[1034,1039],{"type":36,"tag":81,"props":1035,"children":1036},{},[1037],{"type":42,"value":1038},"行銷導向：",{"type":42,"value":1040}," 每一隻狗都有「行銷文案」，志工會幫狗拍照上傳社群，利用網絡力量幫狗找家，而不是被動等民眾走進收容所。",{"type":36,"tag":51,"props":1042,"children":1043},{},[1044],{"type":36,"tag":81,"props":1045,"children":1046},{},[1047],{"type":42,"value":1048},"台灣可仿效之處：",{"type":36,"tag":148,"props":1050,"children":1051},{},[1052],{"type":36,"tag":152,"props":1053,"children":1054},{},[1055,1060,1062,1067],{"type":36,"tag":81,"props":1056,"children":1057},{},[1058],{"type":42,"value":1059},"「公辦民營」的中途補貼制度：",{"type":42,"value":1061}," 台灣目前的中途多半是愛心媽媽自掏腰包，這不可長久。政府應編列預算，",{"type":36,"tag":81,"props":1063,"children":1064},{},[1065],{"type":42,"value":1066},"發薪水或津貼給合格的中途家庭",{"type":42,"value":1068},"。這比蓋一座幾億元的收容所更便宜，且能讓狗在家庭環境中保持良好的社會化，更容易被認養。",{"type":36,"tag":637,"props":1070,"children":1071},{},[],{"type":36,"tag":45,"props":1073,"children":1075},{"id":1074},"德國柏林模式極致的源頭門檻與使用者付費",[1076],{"type":42,"value":1077},"德國柏林模式：極致的「源頭門檻」與「使用者付費」",{"type":36,"tag":51,"props":1079,"children":1080},{},[1081],{"type":36,"tag":81,"props":1082,"children":1083},{},[1084],{"type":42,"value":1085},"借鏡重點：解決「棄養」與「衝動飼養」問題",{"type":36,"tag":51,"props":1087,"children":1088},{},[1089,1091,1096],{"type":42,"value":1090},"德國被公認為動保大國，他們的收容所（Tierheim）不僅像旅館，認養率還高達 90% 以上。他們成功的關鍵不在於多會抓，而在於",{"type":36,"tag":81,"props":1092,"children":1093},{},[1094],{"type":42,"value":1095},"讓人「不敢輕易養」、也「養不起」多餘的狗",{"type":42,"value":883},{"type":36,"tag":51,"props":1098,"children":1099},{},[1100],{"type":36,"tag":81,"props":1101,"children":1102},{},[1103],{"type":42,"value":1017},{"type":36,"tag":148,"props":1105,"children":1106},{},[1107,1124,1134],{"type":36,"tag":152,"props":1108,"children":1109},{},[1110,1115,1117,1122],{"type":36,"tag":81,"props":1111,"children":1112},{},[1113],{"type":42,"value":1114},"高昂的「犬稅」（Hundesteuer）：",{"type":42,"value":1116}," 養第一隻狗每年需繳稅（約數千台幣），",{"type":36,"tag":81,"props":1118,"children":1119},{},[1120],{"type":42,"value":1121},"養第二隻稅金會加倍",{"type":42,"value":1123},"。這直接抑制了囤積心態與非法繁殖。",{"type":36,"tag":152,"props":1125,"children":1126},{},[1127,1132],{"type":36,"tag":81,"props":1128,"children":1129},{},[1130],{"type":42,"value":1131},"考照制度（Hundeführerschein）：",{"type":42,"value":1133}," 飼主在養狗前（或第一年內），必須通過理論與實作考試，證明自己懂得如何照顧與控制狗。",{"type":36,"tag":152,"props":1135,"children":1136},{},[1137,1142],{"type":36,"tag":81,"props":1138,"children":1139},{},[1140],{"type":42,"value":1141},"沒有公立收容所：",{"type":42,"value":1143}," 德國的收容所多由動保協會經營，政府只提供補助。這讓收容所運作更靈活，不像台灣公務員被法規綁死。",{"type":36,"tag":51,"props":1145,"children":1146},{},[1147],{"type":36,"tag":81,"props":1148,"children":1149},{},[1150],{"type":42,"value":1048},{"type":36,"tag":148,"props":1152,"children":1153},{},[1154],{"type":36,"tag":152,"props":1155,"children":1156},{},[1157,1159,1164],{"type":42,"value":1158},"台灣目前的寵物登記費極低，幾乎沒有門檻。若能推動 ",{"type":36,"tag":81,"props":1160,"children":1161},{},[1162],{"type":42,"value":1163},"「飼主責任教育認證」",{"type":42,"value":1165},"（上過課才能養），能有效減少大學生或情侶一時衝動養寵物後棄養的亂象。",{"type":36,"tag":637,"props":1167,"children":1168},{},[],{"type":36,"tag":45,"props":1170,"children":1172},{"id":1171},"荷蘭模式世界第一個無流浪狗國家的-3p-策略",[1173],{"type":42,"value":1174},"荷蘭模式：世界第一個「無流浪狗國家」的 3P 策略",{"type":36,"tag":51,"props":1176,"children":1177},{},[1178],{"type":36,"tag":81,"props":1179,"children":1180},{},[1181],{"type":42,"value":1182},"借鏡重點：解決「現存流浪數量」與「品種迷思」",{"type":36,"tag":51,"props":1184,"children":1185},{},[1186],{"type":42,"value":1187},"荷蘭官方宣稱已無街頭流浪狗，他們並非靠撲殺，而是靠數十年的嚴格執法。",{"type":36,"tag":51,"props":1189,"children":1190},{},[1191],{"type":36,"tag":81,"props":1192,"children":1193},{},[1194],{"type":42,"value":1195},"具體做法（CNVR + 3P）：",{"type":36,"tag":148,"props":1197,"children":1198},{},[1199,1209],{"type":36,"tag":152,"props":1200,"children":1201},{},[1202,1207],{"type":36,"tag":81,"props":1203,"children":1204},{},[1205],{"type":42,"value":1206},"CNVR：",{"type":42,"value":1208}," 捕捉 (Collect)、絕育 (Neuter)、疫苗 (Vaccinate)、回置 (Return)。這點台灣正在做，但荷蘭做得更徹底。",{"type":36,"tag":152,"props":1210,"children":1211},{},[1212,1217],{"type":36,"tag":81,"props":1213,"children":1214},{},[1215],{"type":42,"value":1216},"3P 策略：",{"type":36,"tag":234,"props":1218,"children":1219},{},[1220,1230,1240],{"type":36,"tag":152,"props":1221,"children":1222},{},[1223,1228],{"type":36,"tag":81,"props":1224,"children":1225},{},[1226],{"type":42,"value":1227},"Prevent（預防）：",{"type":42,"value":1229}," 嚴格取締非法繁殖場。",{"type":36,"tag":152,"props":1231,"children":1232},{},[1233,1238],{"type":36,"tag":81,"props":1234,"children":1235},{},[1236],{"type":42,"value":1237},"Protect（保護）：",{"type":42,"value":1239}," 建立動物警察，對虐待或棄養者處以重罰（最高 3 年監禁或約 60 萬台幣罰款）。",{"type":36,"tag":152,"props":1241,"children":1242},{},[1243,1248,1250,1255],{"type":36,"tag":81,"props":1244,"children":1245},{},[1246],{"type":42,"value":1247},"Profit-curbing（提高購買成本）：",{"type":42,"value":1249}," 對購買「品種犬」課重稅，讓民眾覺得 ",{"type":36,"tag":81,"props":1251,"children":1252},{},[1253],{"type":42,"value":1254},"「去收容所認養米克斯」在經濟上是唯一合理的選擇",{"type":42,"value":883},{"type":36,"tag":51,"props":1257,"children":1258},{},[1259],{"type":36,"tag":81,"props":1260,"children":1261},{},[1262],{"type":42,"value":1048},{"type":36,"tag":148,"props":1264,"children":1265},{},[1266],{"type":36,"tag":152,"props":1267,"children":1268},{},[1269,1271,1276],{"type":42,"value":1270},"台灣的「品種犬迷思」很重（大家都想養柴犬、貴賓）。若能透過",{"type":36,"tag":81,"props":1272,"children":1273},{},[1274],{"type":42,"value":1275},"稅收手段提高購買品種犬的成本",{"type":42,"value":1277},"，同時給予米克斯認養更多實質補貼（如荷蘭做法），能有效轉移市場需求。",{"type":36,"tag":637,"props":1279,"children":1280},{},[],{"type":36,"tag":45,"props":1282,"children":1284},{"id":1283},"澳洲模式嚴格的生態分區管理",[1285],{"type":42,"value":1286},"澳洲模式：嚴格的「生態分區管理」",{"type":36,"tag":51,"props":1288,"children":1289},{},[1290],{"type":36,"tag":81,"props":1291,"children":1292},{},[1293],{"type":42,"value":1294},"借鏡重點：解決「石虎/穿山甲被咬死」的生態衝突",{"type":36,"tag":51,"props":1296,"children":1297},{},[1298],{"type":42,"value":1299},"這點對目前的台灣最敏感但也最重要。澳洲非常重視原生物種保護，對於外來種（包括野貓野狗）有嚴格的區域限制。",{"type":36,"tag":51,"props":1301,"children":1302},{},[1303],{"type":36,"tag":81,"props":1304,"children":1305},{},[1306],{"type":42,"value":1017},{"type":36,"tag":148,"props":1308,"children":1309},{},[1310,1320],{"type":36,"tag":152,"props":1311,"children":1312},{},[1313,1318],{"type":36,"tag":81,"props":1314,"children":1315},{},[1316],{"type":42,"value":1317},"禁養區與宵禁：",{"type":42,"value":1319}," 在特定生態敏感區，嚴格禁止養貓狗，或者規定貓狗晚上必須關在屋內（Curfews），否則直接重罰。",{"type":36,"tag":152,"props":1321,"children":1322},{},[1323,1328],{"type":36,"tag":81,"props":1324,"children":1325},{},[1326],{"type":42,"value":1327},"非回置政策：",{"type":42,"value":1329}," 在國家公園或保護區抓到的流浪動物，不會採取 TNR（回置），而是必須移出該區域或進行安樂死（這點台灣目前法規不允許，但移出是可行的）。",{"type":36,"tag":51,"props":1331,"children":1332},{},[1333],{"type":36,"tag":81,"props":1334,"children":1335},{},[1336],{"type":42,"value":1048},{"type":36,"tag":148,"props":1338,"children":1339},{},[1340],{"type":36,"tag":152,"props":1341,"children":1342},{},[1343,1345,1350,1352,1357],{"type":42,"value":1344},"台灣不需要全面撲殺，但急需劃定 ",{"type":36,"tag":81,"props":1346,"children":1347},{},[1348],{"type":42,"value":1349},"「生態敏感紅區」",{"type":42,"value":1351},"（如苗栗石虎棲地）。在這些區域 ",{"type":36,"tag":81,"props":1353,"children":1354},{},[1355],{"type":42,"value":1356},"禁止回置（TNR）",{"type":42,"value":1358}," 任何流浪犬貓，並禁止民眾餵食。將資源集中將這些區域的犬貓全數移出至收容所或都會區，實現「生態與動保的分區共存」。",{"type":36,"tag":45,"props":1360,"children":1362},{"id":1361},"新加坡模式科學化管理的公私協力tnrm-策略",[1363],{"type":42,"value":1364},"新加坡模式：科學化管理的「公私協力」TNRM 策略",{"type":36,"tag":51,"props":1366,"children":1367},{},[1368,1373],{"type":36,"tag":81,"props":1369,"children":1370},{},[1371],{"type":42,"value":1372},"借鏡重點：",{"type":42,"value":1374}," 解決「人犬衝突」與「落實源頭數據管理」",{"type":36,"tag":51,"props":1376,"children":1377},{},[1378,1383],{"type":36,"tag":81,"props":1379,"children":1380},{},[1381],{"type":42,"value":1382},"現況概述：",{"type":42,"value":1384}," 新加坡官方不採取零撲殺口號，而是設定明確的科學指標（KPI），目標在 2023 年前完成 70% 自由放養犬隻絕育。實施 5 年後，公眾對於流浪犬的投訴案件大幅下降 70%，證實透過管理能有效降低社會成本。",{"type":36,"tag":51,"props":1386,"children":1387},{},[1388],{"type":36,"tag":81,"props":1389,"children":1390},{},[1391],{"type":42,"value":1392},"具體做法（TNRM + 合作策略）：",{"type":36,"tag":148,"props":1394,"children":1395},{},[1396,1447],{"type":36,"tag":152,"props":1397,"children":1398},{},[1399,1404],{"type":36,"tag":81,"props":1400,"children":1401},{},[1402],{"type":42,"value":1403},"TNRM 四部曲：",{"type":36,"tag":148,"props":1405,"children":1406},{},[1407,1417,1427,1437],{"type":36,"tag":152,"props":1408,"children":1409},{},[1410,1415],{"type":36,"tag":81,"props":1411,"children":1412},{},[1413],{"type":42,"value":1414},"Trap (捕捉)：",{"type":42,"value":1416}," 以人道方式捕捉。",{"type":36,"tag":152,"props":1418,"children":1419},{},[1420,1425],{"type":36,"tag":81,"props":1421,"children":1422},{},[1423],{"type":42,"value":1424},"Neuter (絕育)：",{"type":42,"value":1426}," 絕育、施打疫苗、植入晶片，並剪左耳尖標記。",{"type":36,"tag":152,"props":1428,"children":1429},{},[1430,1435],{"type":36,"tag":81,"props":1431,"children":1432},{},[1433],{"type":42,"value":1434},"Rehome/Release (安家/釋放)：",{"type":42,"value":1436}," 這是與傳統 TNR 不同之處，優先考慮「復健與送養 (Rehome)」，無法送養者才在合適環境「釋放 (Release)」。",{"type":36,"tag":152,"props":1438,"children":1439},{},[1440,1445],{"type":36,"tag":81,"props":1441,"children":1442},{},[1443],{"type":42,"value":1444},"Manage (管理)：",{"type":42,"value":1446}," 持續監測社區回饋，介入處理人犬衝突。",{"type":36,"tag":152,"props":1448,"children":1449},{},[1450,1455],{"type":36,"tag":81,"props":1451,"children":1452},{},[1453],{"type":42,"value":1454},"公私協力策略 (Public-Private Partnership)：",{"type":36,"tag":148,"props":1456,"children":1457},{},[1458,1468,1478],{"type":36,"tag":152,"props":1459,"children":1460},{},[1461,1466],{"type":36,"tag":81,"props":1462,"children":1463},{},[1464],{"type":42,"value":1465},"Lead Partners (政府領頭)：",{"type":42,"value":1467}," 由國家公園局轄下的 AVS 主導，結合獸醫協會提供醫療資源。",{"type":36,"tag":152,"props":1469,"children":1470},{},[1471,1476],{"type":36,"tag":81,"props":1472,"children":1473},{},[1474],{"type":42,"value":1475},"AWG Collaboration (民間執行)：",{"type":42,"value":1477}," 結合近 10 個動物福利團體 (AWGs) 共同執行，政府給資源，民間出人力與經驗，分工明確。",{"type":36,"tag":152,"props":1479,"children":1480},{},[1481,1486],{"type":36,"tag":81,"props":1482,"children":1483},{},[1484],{"type":42,"value":1485},"Community Outreach (教育推廣)：",{"type":42,"value":1487}," 針對民眾最在意的「吠叫」、「公共安全」與「餵食問題」進行教育與溝通，而非將狗放回後就不管。",{"type":36,"tag":51,"props":1489,"children":1490},{},[1491],{"type":36,"tag":81,"props":1492,"children":1493},{},[1494],{"type":42,"value":1048},{"type":36,"tag":148,"props":1496,"children":1497},{},[1498,1515],{"type":36,"tag":152,"props":1499,"children":1500},{},[1501,1506,1508,1513],{"type":36,"tag":81,"props":1502,"children":1503},{},[1504],{"type":42,"value":1505},"強化「M (管理)」的配套：",{"type":42,"value":1507}," 台灣目前的 TNR 常面臨「回置後社區反彈」的問題（如追車、咬人、噪音）。新加坡將 ",{"type":36,"tag":81,"props":1509,"children":1510},{},[1511],{"type":42,"value":1512},"Manage (管理)",{"type":42,"value":1514}," 列為第四大支柱，主動介入協調社區衝突，這一點是台灣目前極需加強的。",{"type":36,"tag":152,"props":1516,"children":1517},{},[1518,1523,1525,1530],{"type":36,"tag":81,"props":1519,"children":1520},{},[1521],{"type":42,"value":1522},"設定明確的數據目標：",{"type":42,"value":1524}," 新加坡設定「70% 絕育率」作為阻斷繁殖的科學門檻，並定期追蹤「投訴下降率」，這種",{"type":36,"tag":81,"props":1526,"children":1527},{},[1528],{"type":42,"value":1529},"以數據說話",{"type":42,"value":1531},"的治理模式，比單純統計絕育隻數更能說服大眾支持計畫。",{"title":7,"searchDepth":1533,"depth":1533,"links":1534},2,[1535,1543,1544,1548],{"id":39,"depth":1533,"text":43,"children":1536},[1537,1539,1540,1541,1542],{"id":47,"depth":1538,"text":47},3,{"id":104,"depth":1538,"text":107},{"id":122,"depth":1538,"text":125},{"id":191,"depth":1538,"text":194},{"id":418,"depth":1538,"text":418},{"id":445,"depth":1533,"text":445},{"id":450,"depth":1533,"text":450,"children":1545},[1546,1547],{"id":455,"depth":1538,"text":455},{"id":835,"depth":1538,"text":838},{"id":982,"depth":1533,"text":982,"children":1549},[1550,1551,1552,1553,1554],{"id":987,"depth":1538,"text":990},{"id":1074,"depth":1538,"text":1077},{"id":1171,"depth":1538,"text":1174},{"id":1283,"depth":1538,"text":1286},{"id":1361,"depth":1538,"text":1364},"markdown","content:resident:r052.md","content","resident/r052.md","md",1775809025681]