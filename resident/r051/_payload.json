"props":353,"children":354},{},[355],{"type":42,"value":356},"開啟 「桃園市民卡 APP」。",{"type":36,"tag":118,"props":358,"children":359},{},[360],{"type":42,"value":361},"在 APP 首頁或選單中，點選 【會員登入】。",{"type":36,"tag":118,"props":363,"children":364},{},[365],{"type":42,"value":366},"輸入您的帳號密碼完成登入。（若您還不是會員，需先完成註冊。）",{"type":36,"tag":185,"props":368,"children":369},{"start":208},[370],{"type":36,"tag":118,"props":371,"children":372},{},[373],{"type":42,"value":374},"進入個人資料設定",{"type":36,"tag":114,"props":376,"children":377},{},[378,383],{"type":36,"tag":118,"props":379,"children":380},{},[381],{"type":42,"value":382},"登入後，在 APP 底部的選單列，點選 【我的卡證】。",{"type":36,"tag":118,"props":384,"children":385},{},[386],{"type":42,"value":387},"進入頁面後， 在您的姓名下方, 點選 【設定會員資料】。",{"type":36,"tag":185,"props":389,"children":390},{"start":240},[391],{"type":36,"tag":118,"props":392,"children":393},{},[394],{"type":42,"value":395},"新增綁定車號",{"type":36,"tag":114,"props":397,"children":398},{},[399,404,409,414],{"type":36,"tag":118,"props":400,"children":401},{},[402],{"type":42,"value":403},"在會員資料設定頁面中，找到並點選 【我的車號】。",{"type":36,"tag":118,"props":405,"children":406},{},[407],{"type":42,"value":408},"點選 【新增綁定車號】。",{"type":36,"tag":118,"props":410,"children":411},{},[412],{"type":42,"value":413},"輸入您的汽車車牌號碼，並確認車種（汽車）。",{"type":36,"tag":118,"props":415,"children":416},{},[417],{"type":42,"value":418},"點選確認或儲存，即可完成綁定。",{"type":36,"tag":52,"props":420,"children":421},{},[422,427],{"type":36,"tag":58,"props":423,"children":424},{},[425],{"type":42,"value":426},"桃園市民卡 App 繳費 操作流程",{"type":42,"value":428},"：",{"type":36,"tag":185,"props":430,"children":431},{},[432,437,442],{"type":36,"tag":118,"props":433,"children":434},{},[435],{"type":42,"value":436},"進入**「市府服務」/「我要繳費」**功能。",{"type":36,"tag":118,"props":438,"children":439},{},[440],{"type":42,"value":441},"選擇**「停車費」**查繳待繳項目。",{"type":36,"tag":118,"props":443,"children":444},{},[445],{"type":42,"value":446},"在選擇繳費方式時，選擇**「一卡通 MONEY, 悠遊付, 街口支付, 全支付」**並依指示完成付款。",{"typ