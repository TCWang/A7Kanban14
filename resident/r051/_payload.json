待繳停車單；若不使用行動支付，也可直接離場於 14 日內至四大超商多媒體事務機補單繳費。",{"type":36,"tag":45,"props":89,"children":91},{"id":90},"智慧停車繳費簡要模式",[92],{"type":42,"value":90},{"type":36,"tag":52,"props":94,"children":95},{},[96,101,103,106],{"type":36,"tag":58,"props":97,"children":98},{},[99],{"type":42,"value":100},"最簡單的繳費方式：綁定「自動代扣繳」",{"type":42,"value":102},".",{"type":36,"tag":66,"props":104,"children":105},{},[],{"type":42,"value":107},"\n只要設定一次，之後每次停車的費用都會在期限內自動從您的帳戶扣款，完全無需手動操作或掃描單據。",{"type":36,"tag":52,"props":109,"children":110},{},[111],{"type":42,"value":112},"📝 設定步驟（使用桃園市民卡 APP）：",{"type":36,"tag":114,"props":115,"children":116},"ul",{},[117,123,128],{"type":36,"tag":118,"props":119,"children":120},"li",{},[121],{"type":42,"value":122},"下載並開啟 「桃園市民卡 APP」。",{"type":36,"tag":118,"props":124,"children":125},{},[126],{"type":42,"value":127},"綁定車號：按照我們剛剛說明的步驟，將您的汽車車牌號碼綁定進去。 (後面有綁定說明)",{"type":36,"tag":118,"props":129,"children":130},{},[131,133],{"type":42,"value":132},"啟用自動代扣繳：",{"type":36,"tag":114,"props":134,"children":135},{},[136,141,146],{"type":36,"tag":118,"props":137,"children":138},{},[139],{"type":42,"value":140},"進入 APP 內的 【停車服務】 或 【自動扣繳】 相關頁面。",{"type":36,"tag":118,"props":142,"children":143},{},[144],{"type":42,"value":145},"選擇您想使用的支付工具進行綁定（包含：一卡通 MONEY, 悠遊付, 街口支付, 全支付）。",{"type":36,"tag":118,"props":147,"children":148},{},[149],{"type":42,"value":150},"開啟「代扣繳」功能並確認。",{"type":36,"tag":52,"props":152,"children":153},{},[154],{"type":42,"value":155},"💡 為什麼這是最佳的模式？",{"type":36,"tag":114,"props":157,"children":158},{},[159,164,169,174],{"type":36,"tag":118,"props":160,"children":161},{},[162],{"type":42,"value":163},"完全自動化：停車單成立後，系統會自動在截止日前從您綁定的帳戶扣款。",{"type":36,"tag":118,"props":165,"children":166},{},[167],{"type":42,"value":168},"不需拿單、不需掃描：智慧停車柱或地磁感應會自動記錄您的停車資訊，您不用再拿實體停車單。",{"type":36,"tag":118,"props":170,"children":171},{},[172],{"type":42,"value":173},"不怕忘記繳費：避免逾期產生罰單或滯納金。",{"type":36,"tag":118,"props":175,"children":176},{},[177],{"type":42,"value":178},"目前行動支付 95 折, 如果使用桃園市民卡再加碼 95 折！",{"type":36,"tag":45,"props":180,"children":182},{"id":181},"市府智慧停車格使用說明",[183],{"type":42,"value":181},{"type":36,"tag":185,"props":186,"children":187},"ol",{},[188],{"type":36,"tag":118,"props":189,"children":190},{},[191],{"type":42,"value":192},"掃描 QRCode",{"type":36,"tag":114,"props":194,"children":195},{},[196,201],{"type":36,"tag":118,"props":197,"children":198},{},[199],{"type":42,"value":200},"使用下面列舉的行動付費 APP 掃描停車格上 QR Code",{"type":36,"tag":118,"props":202,"children":203},{},[204],{"type":42,"value":205},"可使用的行動付費 APP 包括：歐付寶電子支付, 遠傳心生活,一卡通 MONEY, 停車大聲公, 街口支付, 車麻吉, 悠遊付, icash Pay, GAMAPAY 橘子支付, 全支付, Pi 拍錢包。",{"type":36,"tag":185,"props":207,"children":209},{"start":208},2,[210],{"type":36,"tag":118,"props":211,"children":212},{},[213],{"type":42,"value":214},"完成繳費",{"type":36,"tag":114,"props":216,"children":217},{},[218,223,228,233],{"type":36,"tag":118,"props":219,"children":220},{},[221],{"type":42,"value":222},"在行動支付 APP 中完成繳費。 如果已經綁定車號自動扣款, 則停車後就能直接離開。",{"type":36,"tag":118,"props":224,"children":225},{},[226],{"type":42,"value":227},"若於現場繳費完成, 請於 10 分鐘内駛離停車格, 以免開立新單。",{"type":36,"tag":118,"props":229,"children":230},{},[231],{"type":42,"value":232},"若先行駛離停車格,請於 14 天內使用行動繳費或至四大超商多媒體事務機依據車號補單繳費。",{"type":36,"tag":118,"props":234,"children":235},{},[236],{"type":42,"value":237},"四大超商包含: 7-ELEVEN (統一超商), 全家便利商店 (FamilyMart), 萊爾富 (Hi-Life), OK 便利店 (OK Mart)",{"type":36,"tag":185,"props":239,"children":241},{"start":240},3,[242],{"type":36,"tag":118,"props":243,"children":244},{},[245],{"type":42,"value":246},"注意事項",{"type":36,"tag":114,"props":248,"children":249},{},[250],{"type":36,"tag":118,"props":251,"children":252},{},[253],{"type":42,"value":254},"非持有本市核發之身心障礙者專用停車位識別證者,請依「桃園市公有收費停車場身心障礙者優惠停車查核作業要點」規定,自停車日起七日內洽詢本府交通局委外開單廠商國雲公司,辦理身心障礙停車優惠,途期申請不予受理。",{"type":36,"tag":185,"props":256,"children":258},{"start":257},4,[259],{"type":36,"tag":118,"props":260,"children":261},{},[262],{"type":42,"value":263},"停車相關資訊",{"type":36,"tag":114,"props"