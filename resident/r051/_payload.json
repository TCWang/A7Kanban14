{},[546,551,556],{"type":36,"tag":118,"props":547,"children":548},{},[549],{"type":42,"value":550},"選擇您的付款方式（例如：全支付帳戶餘額、綁定的銀行帳戶/信用卡）。",{"type":36,"tag":118,"props":552,"children":553},{},[554],{"type":42,"value":555},"擇是否要折抵全點。",{"type":36,"tag":118,"props":557,"children":558},{},[559],{"type":42,"value":560},"輸入支付密碼完成付款。",{"type":36,"tag":185,"props":562,"children":564},{"start":563},8,[565,570],{"type":36,"tag":118,"props":566,"children":567},{},[568],{"type":42,"value":569},"完成繳費：繳費完成後，會顯示結果頁面，您可以查看交易明細。",{"type":36,"tag":118,"props":571,"children":572},{},[573],{"type":42,"value":574},"綁定車號: 可藉由綁定車號, 加速下次繳費流程。",{"title":7,"searchDepth":208,"depth":208,"links":576},[577],{"id":39,"depth":208,"text":43,"children":578},[579,580,581,582,583],{"id":47,"depth":240,"text":50},{"id":90,"depth":240,"text":90},{"id":181,"depth":240,"text":181},{"id":319,"depth":240,"text":319},{"id":449,"depth":240,"text":452},"markdown","content:resident:r051.md","content","resident/r051.md","md",1775809025689]